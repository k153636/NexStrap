<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:helpers="using:NexStrap.Helpers"
             x:Class="NexStrap.Views.Pages.StretchResolutionPage"
             x:DataType="vm:StretchResolutionViewModel"
             Background="Transparent">

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="24,20" helpers:AnimationHelper.StaggerChildren="True">

            <TextBlock Text="Stretch Res" FontSize="22" FontWeight="Bold"
                       Foreground="#FFFFFF" Margin="0,0,0,2"/>

            <!-- GPU note -->
            <Border Background="#111111" CornerRadius="8" Padding="14,10"
                    IsVisible="{Binding WarningVisible}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="⚠  GPU scaling must be set to Full-screen for stretch to work"
                                   Foreground="#FFFFFF" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock FontSize="11" Foreground="#888888" TextWrapping="Wrap"
                                   Text="Additional setup may be required depending on your environment."/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕" Command="{Binding DismissWarningCommand}"
                            Background="Transparent" Foreground="#888888"
                            Padding="6,4" FontSize="13" CornerRadius="8"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border CornerRadius="8" Padding="14,10" Background="{DynamicResource CardBg}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0"
                             Fill="#4ADE80" IsVisible="{Binding IsActive}"/>
                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0"
                             Fill="#505050" IsVisible="{Binding IsActive, Converter={x:Static BoolConverters.Not}}"/>
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                               Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="Restore" Command="{Binding RestoreCommand}"
                            IsVisible="{Binding IsActive}"
                            Background="#1AFF4444" Foreground="{DynamicResource FgDanger}"
                            FontSize="11" Padding="12,4" CornerRadius="8"/>
                </Grid>
            </Border>

            <!-- Auto Apply toggle -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="16,12">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Auto Apply" Foreground="#FFFFFF" FontSize="13"/>
                        <TextBlock Text="Apply when Roblox is running, restore on exit"
                                   Foreground="{DynamicResource FgSub}" FontSize="11"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ApplyOnLaunch}"
                                  OnContent="ON" OffContent="OFF"/>
                </Grid>
            </Border>

            <!-- Presets -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="16,14">
                <StackPanel Spacing="12">
                    <TextBlock Text="Presets" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgSub}"/>

                    <ItemsControl ItemsSource="{Binding Presets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding $parent[ItemsControl].DataContext.SelectPresetCommand}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,8,8"
                                        Padding="0" CornerRadius="8"
                                        Background="{DynamicResource CardBg}">
                                    <TextBlock Text="{Binding Label}" Foreground="#FFFFFF"
                                               FontSize="13" Margin="14,10"
                                               Width="110" TextAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Apply Now" Command="{Binding ApplyNowCommand}"
                            HorizontalAlignment="Right"
                            Background="#FFFFFF" Foreground="#080808"
                            FontWeight="SemiBold" FontSize="12" Padding="14,8" CornerRadius="8"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
