<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:helpers="using:NexStrap.Helpers"
             x:Class="NexStrap.Views.Pages.FriendsPage"
             x:DataType="vm:FriendsViewModel"
             Background="Transparent">

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="24,20" helpers:AnimationHelper.StaggerChildren="True">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Friends" FontSize="22" FontWeight="Bold"
                           Foreground="#FFFFFF" Margin="0,0,0,2"/>
                <Button Grid.Column="1" Content="↻"
                        Command="{Binding RefreshAsyncCommand}"
                        Background="{DynamicResource OverlayBg}"
                        Foreground="{DynamicResource SubtextBrush}" FontSize="16"
                        Width="32" Height="32" Padding="0" CornerRadius="8"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- Loading indicator -->
            <TextBlock Text="Loading..." FontSize="12" Foreground="{DynamicResource FgSub}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"
                       IsVisible="{Binding IsLoading}"/>

            <!-- Status / empty message -->
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{DynamicResource FgMuted}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"
                       IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Friends list -->
            <Border Classes="area-panel">
                <ItemsControl ItemsSource="{Binding Friends}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FriendEntryViewModel">
                            <StackPanel>
                            <Border Classes="area-row-compact">
                                <Grid ColumnDefinitions="36,*,Auto">

                                    <!-- Avatar -->
                                    <Border Grid.Column="0" Width="36" Height="36"
                                            CornerRadius="8" ClipToBounds="True"
                                            Background="{DynamicResource OverlayBg}">
                                        <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Spacing="2" Margin="10,0">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                        <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                   Foreground="{Binding StatusColor}"/>
                                        <TextBlock Text="{Binding LastLocation}" FontSize="11"
                                                   Foreground="{DynamicResource FgSub}"
                                                   IsVisible="{Binding IsInGame}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Join button -->
                                    <Button Grid.Column="2" Content="Join"
                                            IsVisible="{Binding IsInGame}"
                                            Background="{DynamicResource OverlayBg}"
                                            Foreground="#4ADE80" FontSize="11"
                                            Padding="12,5" CornerRadius="8"
                                            VerticalAlignment="Center"
                                            Tag="{Binding PlaceId}"
                                            Click="JoinButton_Click"/>

                                </Grid>
                            </Border>
                            <Border Classes="area-divider"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
