<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:helpers="using:NexStrap.Helpers"
             xmlns:views="using:NexStrap.Views"
             x:Class="NexStrap.Views.Pages.ThemePage"
             x:DataType="vm:ThemeViewModel"
             Background="Transparent">

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="24,20" helpers:AnimationHelper.StaggerChildren="True">

            <TextBlock Text="Theme" FontSize="22" FontWeight="Bold"
                       Foreground="#FFFFFF" Margin="0,0,0,2"/>

            <!-- Appearance -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,12">
                <StackPanel Spacing="12">
                    <TextBlock Text="Appearance" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgSub}"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="3">
                            <TextBlock Text="Glass Theme" Foreground="#FFFFFF" FontSize="13"/>
                            <TextBlock Text="Semi-transparent sidebar with background image bleed-through"
                                       Foreground="{DynamicResource FgSub}" FontSize="11"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding GlassThemeEnabled}"
                                      OnContent="" OffContent=""
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- UI Color (Glass only) -->
                    <StackPanel Spacing="10" IsVisible="{Binding GlassThemeEnabled}">
                        <TextBlock Text="UI Color" FontSize="11" Foreground="{DynamicResource FgSub}"/>
                        <WrapPanel Orientation="Horizontal">

                            <Border Margin="0,0,8,8" CornerRadius="20" Padding="2"
                                    BorderThickness="2"
                                    BorderBrush="{Binding IsAccentWhite,
                                        Converter={StaticResource BoolToColorConverter},
                                        ConverterParameter='#FFFFFF,Transparent'}">
                                <Button Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#FFFFFF"
                                        Width="28" Height="28" CornerRadius="18"
                                        Background="#FFFFFF" Padding="0"/>
                            </Border>

                            <Border Margin="0,0,8,8" CornerRadius="20" Padding="2"
                                    BorderThickness="2"
                                    BorderBrush="{Binding IsAccentBlue,
                                        Converter={StaticResource BoolToColorConverter},
                                        ConverterParameter='#6EA8FF,Transparent'}">
                                <Button Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#6EA8FF"
                                        Width="28" Height="28" CornerRadius="18"
                                        Background="#6EA8FF" Padding="0"/>
                            </Border>

                            <Border Margin="0,0,8,8" CornerRadius="20" Padding="2"
                                    BorderThickness="2"
                                    BorderBrush="{Binding IsAccentPurple,
                                        Converter={StaticResource BoolToColorConverter},
                                        ConverterParameter='#B470FF,Transparent'}">
                                <Button Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#B470FF"
                                        Width="28" Height="28" CornerRadius="18"
                                        Background="#B470FF" Padding="0"/>
                            </Border>

                            <Border Margin="0,0,8,8" CornerRadius="20" Padding="2"
                                    BorderThickness="2"
                                    BorderBrush="{Binding IsAccentPink,
                                        Converter={StaticResource BoolToColorConverter},
                                        ConverterParameter='#FF70A6,Transparent'}">
                                <Button Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#FF70A6"
                                        Width="28" Height="28" CornerRadius="18"
                                        Background="#FF70A6" Padding="0"/>
                            </Border>

                            <Border Margin="0,0,8,8" CornerRadius="20" Padding="2"
                                    BorderThickness="2"
                                    BorderBrush="{Binding IsAccentGreen,
                                        Converter={StaticResource BoolToColorConverter},
                                        ConverterParameter='#4ADE80,Transparent'}">
                                <Button Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#4ADE80"
                                        Width="28" Height="28" CornerRadius="18"
                                        Background="#4ADE80" Padding="0"/>
                            </Border>

                            <Border Margin="0,0,8,8" CornerRadius="20" Padding="2"
                                    BorderThickness="2"
                                    BorderBrush="{Binding IsAccentOrange,
                                        Converter={StaticResource BoolToColorConverter},
                                        ConverterParameter='#FFAA44,Transparent'}">
                                <Button Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#FFAA44"
                                        Width="28" Height="28" CornerRadius="18"
                                        Background="#FFAA44" Padding="0"/>
                            </Border>

                            <Border Margin="0,0,8,8" CornerRadius="20" Padding="2"
                                    BorderThickness="2"
                                    BorderBrush="{Binding IsAccentCyan,
                                        Converter={StaticResource BoolToColorConverter},
                                        ConverterParameter='#44DFFF,Transparent'}">
                                <Button Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#44DFFF"
                                        Width="28" Height="28" CornerRadius="18"
                                        Background="#44DFFF" Padding="0"/>
                            </Border>

                            <Border Margin="0,0,8,8" CornerRadius="20" Padding="2"
                                    BorderThickness="2"
                                    BorderBrush="{Binding IsAccentRed,
                                        Converter={StaticResource BoolToColorConverter},
                                        ConverterParameter='#FF5555,Transparent'}">
                                <Button Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#FF5555"
                                        Width="28" Height="28" CornerRadius="18"
                                        Background="#FF5555" Padding="0"/>
                            </Border>

                        </WrapPanel>

                        <!-- Color picker -->
                        <ColorPicker Color="{Binding GlassAccentColorValue}"
                                     HorizontalAlignment="Left"/>

                        <!-- Opacity -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Column="0" Text="UI Opacity" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding GlassOpacityPercent, StringFormat='{}{0:F0}%'}"
                                       FontSize="12" Foreground="{DynamicResource FgSub}" VerticalAlignment="Center" Width="36" TextAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="0" Maximum="100" Value="{Binding GlassOpacityPercent}"
                                Margin="0,2,0,0"/>

                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Background Image -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,12">
                <StackPanel Spacing="12">
                    <TextBlock Text="Background Image" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgSub}"/>

                    <!-- Preview (image set) -->
                    <Border CornerRadius="10" ClipToBounds="True"
                            MaxHeight="320" Background="{DynamicResource InputBg}"
                            IsVisible="{Binding BackgroundImagePath,
                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <Image Source="{Binding BackgroundImagePath,
                                   Converter={StaticResource StringToImageConverter}}"
                               Stretch="Uniform"/>
                    </Border>

                    <!-- Placeholder (no image) -->
                    <Border CornerRadius="10" Height="100" Background="{DynamicResource InputBg}"
                            IsVisible="{Binding BackgroundImagePath,
                                Converter={x:Static StringConverters.IsNullOrEmpty}}">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center" Spacing="6">
                            <PathIcon Data="{StaticResource IconPackage}"
                                      Width="26" Height="26" Foreground="#2A2A2A"/>
                            <TextBlock Text="No image set"
                                       FontSize="11" Foreground="#2A2A2A"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Choose Image"
                                Click="PickImageButton_Click"
                                Background="#FFFFFF" Foreground="#080808"
                                FontWeight="SemiBold" FontSize="12"
                                Padding="14,8" CornerRadius="10"/>
                        <Button Content="Remove"
                                Command="{Binding ClearBackgroundImageCommand}"
                                IsEnabled="{Binding BackgroundImagePath,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="#141414" Foreground="{DynamicResource FgSub}"
                                FontSize="12" Padding="14,8" CornerRadius="10"/>
                    </StackPanel>

                    <!-- Blur -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Blur" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding BackgroundBlurRadius, StringFormat='{}{0:F0}'}"
                                   FontSize="12" Foreground="{DynamicResource FgSub}" VerticalAlignment="Center" Width="28" TextAlignment="Right"/>
                    </Grid>
                    <Slider Minimum="0" Maximum="50" Value="{Binding BackgroundBlurRadius}"
                            Margin="0,2,0,8"/>

                    <!-- Brightness -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Brightness" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding BackgroundImageOpacityPercent, StringFormat='{}{0:F0}%'}"
                                   FontSize="12" Foreground="{DynamicResource FgSub}" VerticalAlignment="Center" Width="36" TextAlignment="Right"/>
                    </Grid>
                    <Slider Minimum="0" Maximum="100" Value="{Binding BackgroundImageOpacityPercent}"
                            Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Loading Screen -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,12">
                <StackPanel Spacing="12">
                    <TextBlock Text="Loading Screen" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgSub}"/>

                    <!-- Preview: exact replica of BootstrapperWindow scaled down -->
                    <Border CornerRadius="12" ClipToBounds="True"
                            Width="352" Height="192" HorizontalAlignment="Left"
                            BorderBrush="#2A2A2A" BorderThickness="1">
                        <Viewbox Stretch="Fill">
                            <!-- Content at native 440×240 size — Viewbox scales to fit -->
                            <Grid Width="440" Height="240">

                                <!-- Base dark bg -->
                                <Rectangle Fill="#080808"/>

                                <!-- Custom loading screen image -->
                                <Image Source="{Binding BootstrapperImagePath,
                                           Converter={StaticResource StringToImageConverter}}"
                                       Stretch="UniformToFill"
                                       Opacity="0.85"
                                       IsVisible="{Binding HasBootstrapperImage}"/>

                                <!-- Dark scrim over image -->
                                <Rectangle Fill="#AA080808"
                                           IsVisible="{Binding HasBootstrapperImage}"/>

                                <!-- Fake title bar -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top"
                                            Margin="12,10" Spacing="7">
                                    <Image Source="avares://NexStrap/Assets/nexstrap.png"
                                           Width="14" Height="14"/>
                                    <TextBlock Text="NexStrap" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#555555" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Center content (matches BootstrapperWindow layout) -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Spacing="16" Margin="40,0,40,24">

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                        <Image Source="avares://NexStrap/Assets/nexstrap.png"
                                               Width="36" Height="36" VerticalAlignment="Center"/>
                                        <TextBlock Text="NexStrap" FontSize="20" FontWeight="Bold"
                                                   Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="Checking for updates..."
                                               FontSize="12" Foreground="#888888"
                                               HorizontalAlignment="Center"/>

                                    <StackPanel Spacing="5">
                                        <ProgressBar IsIndeterminate="True"
                                                     Height="4" Width="320"
                                                     CornerRadius="2"
                                                     Foreground="#FFFFFF"
                                                     Background="#222222"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Cancel button -->
                                <Button Content="Cancel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,0,16"
                                        Background="Transparent"
                                        Foreground="#444444"
                                        FontSize="11"
                                        Padding="18,5"
                                        CornerRadius="7"
                                        BorderBrush="#222222"
                                        BorderThickness="1"
                                        IsHitTestVisible="False"/>

                            </Grid>
                        </Viewbox>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Choose Image"
                                Click="PickBootstrapperImageButton_Click"
                                Background="#FFFFFF" Foreground="#080808"
                                FontWeight="SemiBold" FontSize="12"
                                Padding="14,8" CornerRadius="10"/>
                        <Button Content="Remove"
                                Command="{Binding ClearBootstrapperImageCommand}"
                                IsEnabled="{Binding HasBootstrapperImage}"
                                Background="#141414" Foreground="{DynamicResource FgSub}"
                                FontSize="12" Padding="14,8" CornerRadius="10"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource FgSub}" FontSize="12"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding StatusMessage,
                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
