<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:helpers="using:NexStrap.Helpers"
             x:Class="NexStrap.Views.Pages.DiscordPage"
             x:DataType="vm:DiscordViewModel"
             Background="Transparent">

    <UserControl.Styles>
        <Style Selector="Border.rpc-category-header">
            <Setter Property="Background" Value="{DynamicResource OverlayBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="Border.rpc-category-accent">
            <Setter Property="Width" Value="3"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Opacity" Value="0.8"/>
        </Style>
        <Style Selector="TextBlock.rpc-category-title">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ToggleSwitch.rpc-category-toggle">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="StackPanel.rpc-category-items">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="0:0:0.12"
                                      Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="StackPanel.rpc-category-items:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="24,20" helpers:AnimationHelper.StaggerChildren="True">

            <TextBlock Text="Discord RPC" FontSize="22" FontWeight="Bold"
                       Foreground="#FFFFFF" Margin="0,0,0,2"/>
            <TextBlock Text="Configure your Discord Rich Presence"
                       FontSize="11" Foreground="{DynamicResource FgSub}" Margin="0,0,0,4"/>

            <Border Classes="area-panel">
                <StackPanel Spacing="0">
                    <!-- Connection -->
                    <Border Classes="area-row area-row-first">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Connection" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource FgSub}" VerticalAlignment="Center"/>
                                <Border CornerRadius="8" Padding="8,3" Background="{DynamicResource OverlayBg}">
                                    <TextBlock FontSize="11"
                                               Text="{Binding DiscordAppIdConfigured, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Configured,Not configured'}"
                                               Foreground="{Binding DiscordAppIdConfigured, Converter={StaticResource BoolToStringConverter}, ConverterParameter='#4ADE80,#505050'}"/>
                                </Border>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Rich Presence" Foreground="#FFFFFF" FontSize="13"/>
                                    <TextBlock Text="Show game and launcher status on Discord"
                                               Foreground="{DynamicResource FgSub}" FontSize="11"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" IsChecked="{Binding DiscordRpcEnabled}"
                                              IsEnabled="{Binding DiscordAppIdConfigured}"
                                              OnContent="ON" OffContent="OFF"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Classes="area-divider"/>

                    <!-- Profile -->
                    <Border Classes="area-row">
                        <StackPanel Spacing="12">
                            <Border Classes="rpc-category-header">
                                <Grid ColumnDefinitions="Auto,10,*,10,Auto">
                                    <Border Grid.Column="0" Classes="rpc-category-accent"/>
                                    <TextBlock Grid.Column="2" Text="Profile" Classes="rpc-category-title"/>
                                    <ToggleSwitch Grid.Column="4" Classes="rpc-category-toggle"
                                                  IsChecked="{Binding ProfileEnabled}"
                                                  IsEnabled="{Binding DiscordRpcEnabled}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>
                            </Border>

                            <StackPanel Classes="rpc-category-items" Spacing="12" IsEnabled="{Binding ProfileEnabled}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Show Roblox username" Foreground="#FFFFFF" FontSize="13"/>
                                        <TextBlock Text="Display username next to avatar image"
                                                   Foreground="{DynamicResource FgSub}" FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowRobloxUsername}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto"
                                      IsVisible="{Binding ShowRobloxUsername}">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Use displayName format" Foreground="#FFFFFF" FontSize="13"/>
                                        <TextBlock Text="When enabled: displayName (@username)"
                                                   Foreground="{DynamicResource FgSub}" FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding UseDisplayNameFormat}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Classes="area-divider"/>

                    <!-- Game Information -->
                    <Border Classes="area-row">
                        <StackPanel Spacing="12">
                            <Border Classes="rpc-category-header">
                                <Grid ColumnDefinitions="Auto,10,*,10,Auto">
                                    <Border Grid.Column="0" Classes="rpc-category-accent"/>
                                    <TextBlock Grid.Column="2" Text="Game Information" Classes="rpc-category-title"/>
                                    <ToggleSwitch Grid.Column="4" Classes="rpc-category-toggle"
                                                  IsChecked="{Binding GameInformationEnabled}"
                                                  IsEnabled="{Binding DiscordRpcEnabled}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>
                            </Border>

                            <StackPanel Classes="rpc-category-items" Spacing="12" IsEnabled="{Binding GameInformationEnabled}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Show creator name" Foreground="#FFFFFF" FontSize="13"/>
                                        <TextBlock Text="Appends &quot;by creator&quot; after the game name"
                                                   Foreground="{DynamicResource FgSub}" FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowCreator}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Show server region" Foreground="#FFFFFF" FontSize="13"/>
                                        <TextBlock Text="Shows your country → server region (e.g. JP → US Server)"
                                                   Foreground="{DynamicResource FgSub}" FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowServerRegion}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Show Fast Flags count" Foreground="#FFFFFF" FontSize="13"/>
                                        <TextBlock Text="Shows the number of active Fast Flags (e.g. 12 Flags)"
                                                   Foreground="{DynamicResource FgSub}" FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowFlagCount}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Show place name in local language" Foreground="#FFFFFF" FontSize="13"/>
                                        <TextBlock Text="Use your system language for game names instead of English (en_us)"
                                                   Foreground="{DynamicResource FgSub}" FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding PlaceNameLocalized}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Classes="area-divider"/>

                    <!-- Social -->
                    <Border Classes="area-row">
                        <StackPanel Spacing="12">
                            <Border Classes="rpc-category-header">
                                <Grid ColumnDefinitions="Auto,10,*,10,Auto">
                                    <Border Grid.Column="0" Classes="rpc-category-accent"/>
                                    <TextBlock Grid.Column="2" Text="Social" Classes="rpc-category-title"/>
                                    <ToggleSwitch Grid.Column="4" Classes="rpc-category-toggle"
                                                  IsChecked="{Binding SocialEnabled}"
                                                  IsEnabled="{Binding DiscordRpcEnabled}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>
                            </Border>

                            <StackPanel Classes="rpc-category-items" Spacing="12" IsEnabled="{Binding SocialEnabled}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Show Join Game button" Foreground="#FFFFFF" FontSize="13"/>
                                        <TextBlock Text="Button to join the game directly from Discord"
                                                   Foreground="{DynamicResource FgSub}" FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowJoinButton}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Classes="area-divider"/>

                    <!-- NexStrap -->
                    <Border Classes="area-row area-row-last">
                        <StackPanel Spacing="12">
                            <Border Classes="rpc-category-header">
                                <Grid ColumnDefinitions="Auto,10,*,10,Auto">
                                    <Border Grid.Column="0" Classes="rpc-category-accent"/>
                                    <TextBlock Grid.Column="2" Text="NexStrap" Classes="rpc-category-title"/>
                                    <ToggleSwitch Grid.Column="4" Classes="rpc-category-toggle"
                                                  IsChecked="{Binding NexStrapEnabled}"
                                                  IsEnabled="{Binding DiscordRpcEnabled}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>
                            </Border>

                            <StackPanel Classes="rpc-category-items" Spacing="12" IsEnabled="{Binding NexStrapEnabled}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="NexStrap Presence" Foreground="#FFFFFF" FontSize="13"/>
                                        <TextBlock Text="Show presence while using the launcher outside a game. Turning this off hides NexStrap's RPC entirely."
                                                   Foreground="{DynamicResource FgSub}" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowLauncherPresence}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto"
                                      IsVisible="{Binding ShowLauncherPresence}">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Show current page" Foreground="#FFFFFF" FontSize="13"/>
                                        <TextBlock Text="Show the current page name in the details line"
                                                   Foreground="{DynamicResource FgSub}" FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowLauncherDetails}"
                                                  OnContent="ON" OffContent="OFF"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
