<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:models="using:NexStrap.Core.Models"
             x:Class="NexStrap.Views.Pages.ModsPage"
             x:DataType="vm:ModsViewModel"
             Background="#080808">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,28,32,16" Spacing="4">
            <TextBlock Text="Mod マネージャー" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"/>
            <TextBlock Text="テクスチャ・サウンド・フォントなどのカスタムアセットを管理"
                       FontSize="13" Foreground="#888888"/>
        </StackPanel>

        <!-- Action Bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12"
                    Margin="32,0,32,20">
            <Button Content="+ Mod をインポート"
                    Command="{Binding ImportModCommand}"
                    Background="#FFFFFF" Foreground="#080808" FontWeight="SemiBold"
                    Padding="16,8" CornerRadius="8"/>
            <Button Content="全 Mod を適用"
                    Command="{Binding ApplyModsCommand}"
                    IsEnabled="{Binding !IsLoading}"
                    Background="#202020" Foreground="#FFFFFF"
                    Padding="16,8" CornerRadius="8"/>
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#CCCCCC" VerticalAlignment="Center"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>

        <!-- Mods Grid -->
        <ScrollViewer Grid.Row="2" Margin="32,0,32,0">
            <ItemsControl ItemsSource="{Binding Mods}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Mod">
                        <Border Width="200" Margin="0,0,16,16"
                                Background="#141414" CornerRadius="12"
                                Padding="16">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                <!-- Type Badge -->
                                <Border Grid.Row="0" Background="#202020" CornerRadius="8"
                                        Padding="8,4" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding TypeLabel}"
                                               FontSize="11" Foreground="#888888"/>
                                </Border>

                                <!-- Name -->
                                <TextBlock Grid.Row="1" Text="{Binding Name}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" Margin="0,10,0,4"
                                           TextWrapping="Wrap"/>

                                <!-- Description -->
                                <TextBlock Grid.Row="2" Text="{Binding Description}"
                                           FontSize="12" Foreground="#888888"
                                           TextWrapping="Wrap" MaxHeight="40"/>

                                <!-- Toggle -->
                                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding IsEnabled, Converter={StaticResource BoolToStringConverter}, ConverterParameter='有効,無効'}"
                                               FontSize="12" Foreground="#888888"
                                               VerticalAlignment="Center"/>
                                    <ToggleSwitch Grid.Column="1"
                                                  IsChecked="{Binding IsEnabled}"
                                                  OnContent="" OffContent=""
                                                  Width="40"/>
                                </Grid>

                                <!-- Remove Button -->
                                <Button Grid.Row="4"
                                        Content="削除"
                                        Command="{Binding $parent[UserControl].((vm:ModsViewModel)DataContext).RemoveModCommand}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        Foreground="#888888"
                                        BorderBrush="#2E2E2E" BorderThickness="1"
                                        Padding="8,4" CornerRadius="6"
                                        Margin="0,8,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="12"
                    IsVisible="{Binding Mods.Count, Converter={StaticResource IntToZeroConverter}}">
            <PathIcon Data="{StaticResource IconPackage}" Width="48" Height="48"
                      Foreground="#505050" HorizontalAlignment="Center"/>
            <TextBlock Text="Mod がありません" FontSize="16" Foreground="#888888"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="「+ Mod をインポート」でフォルダを追加してください"
                       FontSize="13" Foreground="#505050"
                       HorizontalAlignment="Center"/>
        </StackPanel>

    </Grid>
</UserControl>
