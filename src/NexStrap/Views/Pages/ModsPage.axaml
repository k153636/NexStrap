<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:models="using:NexStrap.Core.Models"
             x:Class="NexStrap.Views.Pages.ModsPage"
             x:DataType="vm:ModsViewModel"
             Background="#080808">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,28,32,16" Spacing="6">
            <TextBlock Text="Mods" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF"/>
            <TextBlock Text="テクスチャ・サウンド・フォントなどのカスタムアセットを管理"
                       FontSize="14" Foreground="#505050"/>
        </StackPanel>

        <!-- Action Bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="32,0,32,16">
            <Button Content="+ Mod をインポート"
                    Command="{Binding ImportModCommand}"
                    Background="#FFFFFF" Foreground="#080808" FontWeight="SemiBold"
                    Padding="20,12" CornerRadius="14"/>
            <Button Content="全 Mod を適用"
                    Command="{Binding ApplyModsCommand}"
                    IsEnabled="{Binding !IsLoading}"
                    Background="#141414" Foreground="#FFFFFF"
                    Padding="20,12" CornerRadius="14"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#888888"
                       VerticalAlignment="Center"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>

        <!-- Mods Grid -->
        <ScrollViewer Grid.Row="2" Margin="32,0,32,0">
            <ItemsControl ItemsSource="{Binding Mods}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Mod">
                        <Border Width="210" Margin="0,0,16,16"
                                Background="#141414" CornerRadius="18" Padding="20">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                <Border Grid.Row="0" Background="#202020" CornerRadius="10"
                                        Padding="10,5" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding TypeLabel}" FontSize="11" Foreground="#888888"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="{Binding Name}"
                                           FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFF"
                                           Margin="0,12,0,4" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Text="{Binding Description}"
                                           FontSize="12" Foreground="#505050"
                                           TextWrapping="Wrap" MaxHeight="40"/>
                                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding IsEnabled, Converter={StaticResource BoolToStringConverter}, ConverterParameter='有効,無効'}"
                                               FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}"
                                                  OnContent="" OffContent="" Width="40"/>
                                </Grid>
                                <Button Grid.Row="4" Content="削除"
                                        Command="{Binding $parent[UserControl].((vm:ModsViewModel)DataContext).RemoveModCommand}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent" Foreground="#505050"
                                        BorderBrush="#2E2E2E" BorderThickness="1"
                                        Padding="8,6" CornerRadius="10" Margin="0,10,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="16"
                    IsVisible="{Binding Mods.Count, Converter={StaticResource IntToZeroConverter}}">
            <PathIcon Data="{StaticResource IconPackage}" Width="52" Height="52"
                      Foreground="#2E2E2E" HorizontalAlignment="Center"/>
            <StackPanel Spacing="6" HorizontalAlignment="Center">
                <TextBlock Text="Mod がありません" FontSize="16" Foreground="#505050"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="「+ Mod をインポート」でフォルダを追加してください"
                           FontSize="13" Foreground="#2E2E2E" HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</UserControl>
