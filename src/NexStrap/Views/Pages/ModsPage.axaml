<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:models="using:NexStrap.Core.Models"
             x:Class="NexStrap.Views.Pages.ModsPage"
             x:DataType="vm:ModsViewModel"
             Background="Transparent">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="24,20,24,12" Spacing="3">
            <TextBlock Text="Mods" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF"/>
        </StackPanel>

        <!-- Action Bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="24,0,24,12">
            <Button Content="+ Import Mod"
                    Click="ImportButton_Click"
                    Background="#FFFFFF" Foreground="#080808" FontWeight="SemiBold"
                    FontSize="12" Padding="14,8" CornerRadius="10"/>
            <Button Content="Apply All Mods"
                    Command="{Binding ApplyModsCommand}"
                    IsEnabled="{Binding !IsLoading}"
                    Background="{DynamicResource SurfaceBg}" Foreground="#FFFFFF"
                    FontSize="12" Padding="14,8" CornerRadius="10"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#888888" FontSize="12"
                       VerticalAlignment="Center"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>

        <!-- Mods Grid -->
        <ScrollViewer Grid.Row="2" Margin="24,0,24,0">
            <ItemsControl ItemsSource="{Binding Mods}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Mod">
                        <Border Width="185" Margin="0,0,12,12"
                                Background="{DynamicResource SurfaceBg}" CornerRadius="14" Padding="14">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                <Border Grid.Row="0" Background="{DynamicResource ElevatedBg}" CornerRadius="8"
                                        Padding="8,4" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding TypeLabel}" FontSize="11" Foreground="#888888"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="{Binding Name}"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF"
                                           Margin="0,8,0,3" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Text="{Binding Description}"
                                           FontSize="11" Foreground="#505050"
                                           TextWrapping="Wrap" MaxHeight="36"/>
                                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding IsEnabled, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Enabled,Disabled'}"
                                               FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                                    <ToggleSwitch Grid.Column="1"
                                                  IsChecked="{Binding IsEnabled}"
                                                  Command="{Binding $parent[UserControl].DataContext.ToggleModCommand}"
                                                  CommandParameter="{Binding}"
                                                  OnContent="" OffContent="" Width="40"/>
                                </Grid>
                                <Button Grid.Row="4" Content="Remove"
                                        Command="{Binding $parent[UserControl].DataContext.RemoveModCommand}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent" Foreground="#505050"
                                        BorderBrush="#2E2E2E" BorderThickness="1" FontSize="11"
                                        Padding="8,5" CornerRadius="8" Margin="0,8,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="12"
                    IsVisible="{Binding Mods.Count, Converter={StaticResource IntToZeroConverter}}">
            <PathIcon Data="{StaticResource IconPackage}" Width="40" Height="40"
                      Foreground="#2E2E2E" HorizontalAlignment="Center"/>
            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="No mods installed" FontSize="14" Foreground="#505050"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Click &quot;+ Import Mod&quot; to add a folder"
                           FontSize="12" Foreground="#2E2E2E" HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</UserControl>
