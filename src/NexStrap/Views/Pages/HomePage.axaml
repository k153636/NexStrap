<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:local="using:NexStrap.ViewModels"
             x:Class="NexStrap.Views.Pages.HomePage"
             x:DataType="vm:HomeViewModel"
             Background="Transparent">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header: title + badges -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="24,20,24,0">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="NexStrap" FontSize="22" FontWeight="Bold"
                           Foreground="#FFFFFF"/>
                <TextBlock Text="{Binding RobloxVersion}"
                           FontSize="11" Foreground="#444444"
                           FontFamily="Consolas,monospace"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Bottom">
                <Border Background="{DynamicResource CardBg}" CornerRadius="20" Padding="10,4"
                        BorderBrush="#1E1E1E" BorderThickness="1"
                        IsVisible="{Binding IsRobloxRunning}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Ellipse Width="5" Height="5" Fill="#4ADE80"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="実行中" FontSize="11" Foreground="#888888"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource CardBg}" CornerRadius="20" Padding="10,4"
                        BorderBrush="#1E1E1E" BorderThickness="1"
                        IsVisible="{Binding IsLaunching}">
                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                               Foreground="#555555"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Recent Games -->
        <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Spacing="0" Margin="24,0">

                <Border Height="1" Background="{DynamicResource SurfaceBg}" Margin="0,0,0,12"/>

                <!-- Empty state -->
                <TextBlock Text="最近のゲームはありません" FontSize="12" Foreground="#2E2E2E"
                           HorizontalAlignment="Center" Margin="0,24,0,0"
                           IsVisible="{Binding RecentGames.Count,
                               Converter={StaticResource IntToZeroConverter}}"/>

                <ItemsControl ItemsSource="{Binding RecentGames}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="local:GameEntryViewModel">
                            <Border Background="{DynamicResource CardBg}" CornerRadius="10" Padding="12,10"
                                    Margin="0,0,0,8">
                                <Grid ColumnDefinitions="36,*,Auto">
                                    <!-- Icon -->
                                    <Border Grid.Column="0" Width="36" Height="36"
                                            CornerRadius="8" ClipToBounds="True"
                                            Background="{DynamicResource OverlayBg}">
                                        <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                    </Border>
                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Spacing="2" Margin="10,0">
                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#FFFFFF"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding PlayedAt,
                                                StringFormat='{}{0:MM/dd HH:mm}'}"
                                                FontSize="11" Foreground="#444444"/>
                                            <TextBlock FontSize="11" Foreground="#444444"
                                                IsVisible="{Binding DurationSeconds,
                                                    Converter={StaticResource IntToZeroConverter},
                                                    ConverterParameter=invert}"
                                                Text="{Binding DurationSeconds,
                                                    Converter={StaticResource SecondsToTimeConverter}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- Rejoin button -->
                                    <Button Grid.Column="2"
                                            Command="{Binding $parent[UserControl].DataContext.RejoinGameCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource OverlayBg}" Foreground="#888888"
                                            FontSize="11" Padding="10,5" CornerRadius="8">
                                        再参加
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- Launch button pinned to bottom -->
        <Button Grid.Row="2"
                Command="{Binding LaunchRobloxCommand}"
                IsEnabled="{Binding !IsLaunching}"
                HorizontalAlignment="Stretch"
                Margin="24,0,24,20"
                Padding="0,14" CornerRadius="10"
                Background="#FFFFFF">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <PathIcon Data="{StaticResource IconPlay}" Width="13" Height="13"
                          Foreground="#080808" VerticalAlignment="Center"/>
                <TextBlock Text="起動" FontSize="13" FontWeight="SemiBold"
                           Foreground="#080808" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

    </Grid>

</UserControl>
