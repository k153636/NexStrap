<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             x:Class="NexStrap.Views.Pages.HomePage"
             x:DataType="vm:HomeViewModel"
             Background="#080808">

    <ScrollViewer>
        <StackPanel Spacing="32" Margin="48,40">

            <!-- Hero -->
            <StackPanel Spacing="12">
                <TextBlock Text="NexStrap" FontSize="36" FontWeight="Bold" Foreground="#FFFFFF"/>
                <TextBlock Text="次世代 Roblox ブートストラッパー" FontSize="14" Foreground="#505050"/>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Border Background="#141414" CornerRadius="20" Padding="12,5">
                        <TextBlock Text="{Binding RobloxVersion}" FontSize="12" Foreground="#888888"/>
                    </Border>
                    <Border Background="#141414" CornerRadius="20" Padding="12,5"
                            IsVisible="{Binding IsRobloxRunning}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="6" Height="6" Fill="#FFFFFF"/>
                            <TextBlock Text="実行中" FontSize="12" Foreground="#FFFFFF"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Status Bar -->
            <Border Background="#141414" CornerRadius="16" Padding="20,14">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,12,0"
                             VerticalAlignment="Center" Fill="#FFFFFF"/>
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                               Foreground="#CCCCCC" VerticalAlignment="Center" FontSize="13"/>
                    <TextBlock Grid.Column="2" Text="Roblox が見つかりません"
                               Foreground="#505050" FontSize="12" VerticalAlignment="Center"
                               IsVisible="{Binding !IsRobloxInstalled}"/>
                </Grid>
            </Border>

            <!-- Launch Buttons -->
            <Grid ColumnDefinitions="*,16,*">
                <Button Grid.Column="0"
                        Command="{Binding LaunchRobloxCommand}"
                        IsEnabled="{Binding !IsLaunching}"
                        HorizontalAlignment="Stretch"
                        Padding="0,28"
                        CornerRadius="20"
                        Background="#FFFFFF">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource IconPlay}" Width="24" Height="24"
                                  Foreground="#080808" HorizontalAlignment="Center"/>
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Roblox を起動" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#080808" HorizontalAlignment="Center"/>
                            <TextBlock Text="Flags &amp; Mods を適用して起動"
                                       FontSize="11" Foreground="#505050"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Command="{Binding LaunchMultipleCommand}"
                        IsEnabled="{Binding !IsLaunching}"
                        HorizontalAlignment="Stretch"
                        Padding="0,28"
                        CornerRadius="20"
                        Background="#141414">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource IconMulti}" Width="24" Height="24"
                                  Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="マルチ起動" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <TextBlock Text="複数インスタンス同時起動"
                                       FontSize="11" Foreground="#505050"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Quick Actions -->
            <StackPanel Spacing="16">
                <TextBlock Text="クイックアクション" FontSize="12" FontWeight="SemiBold"
                           Foreground="#505050" Margin="4,0"/>
                <Grid ColumnDefinitions="*,12,*,12,*">
                    <Button Grid.Column="0" Command="{Binding HotReloadFlagsCommand}"
                            Padding="0,20" CornerRadius="16" Background="#141414"
                            HorizontalAlignment="Stretch">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconFlash}" Width="20" Height="20"
                                      Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="ホットリロード" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Padding="0,20" CornerRadius="16"
                            Background="#141414" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconStats}" Width="20" Height="20"
                                      Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="パフォーマンス" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" Padding="0,20" CornerRadius="16"
                            Background="#141414" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPackage}" Width="20" Height="20"
                                      Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="プロファイル" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Info -->
            <Border Background="#141414" CornerRadius="16" Padding="24,20">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconInfo}" Width="13" Height="13"
                                  Foreground="#505050"/>
                        <TextBlock Text="NexStrap について" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#505050"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="#888888" FontSize="13" LineHeight="22">
                        Fast Flags のホットリロードは Roblox 起動中でも次回ゲーム参加時に反映されます。
                        ブラウザ機能でゲームをプレイしながら動画視聴が可能です。
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
