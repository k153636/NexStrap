<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:local="using:NexStrap.ViewModels"
             xmlns:helpers="using:NexStrap.Helpers"
             x:Class="NexStrap.Views.Pages.HomePage"
             x:DataType="vm:HomeViewModel"
             Background="Transparent">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="24,20,24,0" Spacing="3">
            <TextBlock Text="Home" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF"/>
            <TextBlock Text="Your recent games and favorites"
                       FontSize="11" Foreground="{DynamicResource FgSub}"/>
        </StackPanel>

        <!-- Game List -->
        <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Spacing="0" Margin="24,0" helpers:AnimationHelper.StaggerChildren="True">

                <Border Height="1" Background="{DynamicResource SurfaceBg}" Margin="0,0,0,12"/>

                <!-- Favorites section -->
                <StackPanel Spacing="8" Margin="0,0,0,16"
                            IsVisible="{Binding FavoriteGames.Count,
                                Converter={StaticResource IntToZeroConverter},
                                ConverterParameter=invert}">
                    <TextBlock Text="Favorites" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgSub}" Margin="2,0,0,0"/>
                    <ItemsControl ItemsSource="{Binding FavoriteGames}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="local:GameEntryViewModel">
                                <Border Background="{DynamicResource CardBg}" CornerRadius="8"
                                        Padding="14,12" Margin="0,0,0,6" Classes="card"
                                        BoxShadow="0 2 8 0 #1A000000">
                                    <Grid ColumnDefinitions="52,*,Auto,6,Auto">
                                                        <Border Grid.Column="0" Width="52" Height="52"
                                                CornerRadius="8" ClipToBounds="True"
                                                Background="{DynamicResource OverlayBg}">
                                            <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" Margin="12,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14"
                                                       FontWeight="SemiBold" Foreground="#FFFFFF"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding DisplayDurationSeconds,
                                                           Converter={StaticResource SecondsToTimeConverter}}"
                                                       FontSize="11" Foreground="{DynamicResource FgSub}"
                                                       IsVisible="{Binding DisplayDurationSeconds,
                                                           Converter={StaticResource IntToZeroConverter},
                                                           ConverterParameter=invert}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Command="{Binding $parent[UserControl].DataContext.ToggleFavoriteCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="#FFCC44"
                                                FontSize="14" Padding="6,4" CornerRadius="8">
                                            ★
                                        </Button>
                                        <Button Grid.Column="4"
                                                Command="{Binding $parent[UserControl].DataContext.RejoinGameCommand}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource OverlayBg}"
                                                Foreground="{DynamicResource SubtextBrush}"
                                                FontSize="11" Padding="10,5" CornerRadius="8">
                                            Rejoin
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Recent Games header + sort -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0" Text="Recent Games" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgSub}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Command="{Binding ToggleSortMenuCommand}"
                            Background="{DynamicResource OverlayBg}" CornerRadius="8" Padding="8,3">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="↕" FontSize="10" Foreground="{DynamicResource FgSub}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SortLabel}" FontSize="10"
                                       Foreground="{DynamicResource FgSub}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Sort dropdown -->
                <Border IsVisible="{Binding IsSortMenuOpen}"
                        Background="{DynamicResource CardBg}" CornerRadius="8"
                        Padding="4" Margin="0,0,0,4">
                    <StackPanel>
                        <Button Content="Recent First"
                                Command="{Binding SetHomeSortCommand}"
                                CommandParameter="{x:Static local:HomeSortMode.RecentFirst}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Padding="10,6" CornerRadius="8"
                                Foreground="{Binding IsSortRecent,
                                    Converter={StaticResource BoolToColorConverter},
                                    ConverterParameter='#FFFFFF,#505050'}"/>
                        <Button Content="Most Played"
                                Command="{Binding SetHomeSortCommand}"
                                CommandParameter="{x:Static local:HomeSortMode.TotalTime}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Padding="10,6" CornerRadius="8"
                                Foreground="{Binding IsSortTotalTime,
                                    Converter={StaticResource BoolToColorConverter},
                                    ConverterParameter='#FFFFFF,#505050'}"/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <Border IsVisible="{Binding RecentGames.Count, Converter={StaticResource IntToZeroConverter}}"
                        Padding="20,20" CornerRadius="8" Background="#0DFFFFFF" Margin="0,4,0,0">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Text="Ready to play?" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300"
                                   FontSize="12" Foreground="{DynamicResource FgSub}"
                                   Text="Hit Launch below to start Roblox. Your game history will appear here."/>
                    </StackPanel>
                </Border>

                <!-- Game cards -->
                <ItemsControl ItemsSource="{Binding RecentGames}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="local:GameEntryViewModel">
                            <Border Background="{DynamicResource CardBg}" CornerRadius="8"
                                    Padding="12,10" Margin="0,0,0,6" Classes="card"
                                    BoxShadow="0 2 8 0 #1A000000">
                                <Grid ColumnDefinitions="44,*,Auto,6,Auto">
                                    <Border Grid.Column="0" Width="44" Height="44"
                                            CornerRadius="8" ClipToBounds="True"
                                            Background="{DynamicResource OverlayBg}">
                                        <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" Margin="10,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#FFFFFF"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding PlayedAt,
                                                           StringFormat='{}{0:MM/dd HH:mm}'}"
                                                       FontSize="11" Foreground="{DynamicResource FgSub}"/>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource FgSub}"
                                                       IsVisible="{Binding DisplayDurationSeconds,
                                                           Converter={StaticResource IntToZeroConverter},
                                                           ConverterParameter=invert}"
                                                       Text="{Binding DisplayDurationSeconds,
                                                           Converter={StaticResource SecondsToTimeConverter}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Command="{Binding $parent[UserControl].DataContext.ToggleFavoriteCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Padding="6,4" CornerRadius="8"
                                            Foreground="{Binding IsFavorite,
                                                Converter={StaticResource BoolToColorConverter},
                                                ConverterParameter='#FFCC44,#333333'}">
                                        <TextBlock Text="{Binding IsFavorite,
                                                       Converter={StaticResource BoolToStringConverter},
                                                       ConverterParameter='★,☆'}"
                                                   FontSize="14"/>
                                    </Button>
                                    <Button Grid.Column="4"
                                            Command="{Binding $parent[UserControl].DataContext.RejoinGameCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource OverlayBg}"
                                            Foreground="{DynamicResource SubtextBrush}"
                                            FontSize="11" Padding="10,5" CornerRadius="8">
                                        Rejoin
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>


    </Grid>

</UserControl>
