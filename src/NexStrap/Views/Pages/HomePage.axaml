<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             x:Class="NexStrap.Views.Pages.HomePage"
             x:DataType="vm:HomeViewModel"
             Background="#080808">

    <ScrollViewer>
        <StackPanel Spacing="20" Margin="32,28">

            <!-- Hero -->
            <StackPanel Spacing="6">
                <TextBlock Text="NexStrap" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF"/>
                <!-- 通常時はサブタイトル、起動中/プレイ中はステータスを表示 -->
                <TextBlock FontSize="13" Foreground="#505050">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}">
                            <Binding Path="StatusText"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                    <Border Background="#141414" CornerRadius="16" Padding="10,4">
                        <TextBlock Text="{Binding RobloxVersion}" FontSize="11" Foreground="#505050"/>
                    </Border>
                    <Border Background="#141414" CornerRadius="16" Padding="10,4"
                            IsVisible="{Binding IsRobloxRunning}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Ellipse Width="5" Height="5" Fill="#FFFFFF"/>
                            <TextBlock Text="実行中" FontSize="11" Foreground="#CCCCCC"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Launch Buttons -->
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        Command="{Binding LaunchRobloxCommand}"
                        IsEnabled="{Binding !IsLaunching}"
                        HorizontalAlignment="Stretch"
                        Padding="0,22" CornerRadius="16" Background="#FFFFFF">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource IconPlay}" Width="20" Height="20"
                                  Foreground="#080808" HorizontalAlignment="Center"/>
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="Roblox を起動" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#080808" HorizontalAlignment="Center"/>
                            <TextBlock Text="Flags &amp; Mods を適用して起動"
                                       FontSize="11" Foreground="#505050"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Command="{Binding LaunchMultipleCommand}"
                        IsEnabled="{Binding !IsLaunching}"
                        HorizontalAlignment="Stretch"
                        Padding="0,22" CornerRadius="16" Background="#141414">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource IconMulti}" Width="20" Height="20"
                                  Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="マルチ起動" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <TextBlock Text="複数インスタンス同時起動"
                                       FontSize="11" Foreground="#505050"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Quick Actions -->
            <StackPanel Spacing="10">
                <TextBlock Text="クイックアクション" FontSize="11" FontWeight="SemiBold"
                           Foreground="#505050" Margin="2,0"/>
                <Grid ColumnDefinitions="*,10,*,10,*">
                    <Button Grid.Column="0" Command="{Binding HotReloadFlagsCommand}"
                            Padding="0,16" CornerRadius="14" Background="#141414"
                            HorizontalAlignment="Stretch">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconFlash}" Width="18" Height="18"
                                      Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="ホットリロード" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Padding="0,16" CornerRadius="14"
                            Background="#141414" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconStats}" Width="18" Height="18"
                                      Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="パフォーマンス" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" Padding="0,16" CornerRadius="14"
                            Background="#141414" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPackage}" Width="18" Height="18"
                                      Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="プロファイル" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Info -->
            <Border Background="#141414" CornerRadius="14" Padding="18,14">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource IconInfo}" Width="12" Height="12"
                                  Foreground="#505050"/>
                        <TextBlock Text="NexStrap について" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#505050"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="#888888" FontSize="12" LineHeight="20">
                        Fast Flags のホットリロードは Roblox 起動中でも次回ゲーム参加時に反映されます。
                        ブラウザ機能でゲームをプレイしながら動画視聴が可能です。
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
