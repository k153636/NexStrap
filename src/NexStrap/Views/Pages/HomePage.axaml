<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             x:Class="NexStrap.Views.Pages.HomePage"
             x:DataType="vm:HomeViewModel"
             Background="#080808">

    <Grid RowDefinitions="*,Auto">

        <!-- Center content -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center"
                    Margin="24,0" Spacing="16">

            <!-- Branding -->
            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="NexStrap" FontSize="22" FontWeight="Bold"
                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="5"
                            HorizontalAlignment="Center">
                    <Border Background="#111111" CornerRadius="20" Padding="10,4"
                            BorderBrush="#1E1E1E" BorderThickness="1">
                        <TextBlock Text="{Binding RobloxVersion}" FontSize="11"
                                   Foreground="#444444" FontFamily="Consolas,monospace"/>
                    </Border>
                    <Border Background="#111111" CornerRadius="20" Padding="10,4"
                            BorderBrush="#1E1E1E" BorderThickness="1"
                            IsVisible="{Binding IsRobloxRunning}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Ellipse Width="5" Height="5" Fill="#4ADE80"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="実行中" FontSize="11" Foreground="#666666"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#111111" CornerRadius="20" Padding="10,4"
                            BorderBrush="#1E1E1E" BorderThickness="1"
                            IsVisible="{Binding IsLaunching}">
                        <TextBlock Text="{Binding StatusText}" FontSize="11"
                                   Foreground="#444444"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Launch Button -->
            <Button Command="{Binding LaunchRobloxCommand}"
                    IsEnabled="{Binding !IsLaunching}"
                    HorizontalAlignment="Stretch"
                    Padding="0,14" CornerRadius="12"
                    Background="#FFFFFF">
                <StackPanel Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center">
                    <PathIcon Data="{StaticResource IconPlay}" Width="14" Height="14"
                              Foreground="#080808" VerticalAlignment="Center"/>
                    <TextBlock Text="起動" FontSize="13" FontWeight="SemiBold"
                               Foreground="#080808" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>

        <!-- Bottom: Hot Reload -->
        <Button Grid.Row="1"
                Command="{Binding HotReloadFlagsCommand}"
                HorizontalAlignment="Stretch"
                Margin="24,0,24,20"
                Padding="14,8" CornerRadius="10"
                Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*">
                <PathIcon Grid.Column="0" Data="{StaticResource IconFlash}"
                          Width="11" Height="11" Foreground="#3A3A3A"/>
                <TextBlock Grid.Column="1" Text="Fast Flags をホットリロード"
                           FontSize="11" Foreground="#3A3A3A"
                           Margin="8,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Button>

    </Grid>

</UserControl>
