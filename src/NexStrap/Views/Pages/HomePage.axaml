<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:NexStrap.ViewModels"
             x:Class="NexStrap.Views.Pages.HomePage"
             x:DataType="vm:HomeViewModel"
             Background="#080808">

    <ScrollViewer>
        <StackPanel Spacing="24" Margin="32,28">

            <!-- Hero Section -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock Text="NexStrap" FontSize="32" FontWeight="Bold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="次世代 Roblox ブートストラッパー"
                               FontSize="14" Foreground="#888888"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <Border Background="#202020" CornerRadius="12" Padding="10,4">
                            <TextBlock Text="{Binding RobloxVersion}"
                                       FontSize="12" Foreground="#CCCCCC"/>
                        </Border>
                        <Border Background="#202020" CornerRadius="12" Padding="10,4"
                                IsVisible="{Binding IsRobloxRunning}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Ellipse Width="6" Height="6" Fill="#FFFFFF"/>
                                <TextBlock Text="実行中" FontSize="12" Foreground="#FFFFFF"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Version Badge -->
                <Border Grid.Column="1" Background="#141414" CornerRadius="12"
                        Padding="16,12" VerticalAlignment="Top">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="v1.0.0" FontSize="18" FontWeight="Bold"
                                   Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                        <TextBlock Text="NexStrap" FontSize="11"
                                   Foreground="#888888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status Bar -->
            <Border Background="#141414" CornerRadius="10" Padding="16,12">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,10,0"
                             VerticalAlignment="Center" Fill="#FFFFFF"/>
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                               Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Roblox が見つかりません"
                               Foreground="#888888" FontSize="12"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !IsRobloxInstalled}"/>
                </Grid>
            </Border>

            <!-- Launch Buttons -->
            <Grid ColumnDefinitions="*,16,*">
                <!-- Primary Launch -->
                <Button Grid.Column="0"
                        Command="{Binding LaunchRobloxCommand}"
                        IsEnabled="{Binding !IsLaunching}"
                        HorizontalAlignment="Stretch"
                        Padding="0,20"
                        CornerRadius="10"
                        Background="#202020">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource IconPlay}" Width="22" Height="22"
                                  Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Roblox を起動" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Flags &amp; Mods を適用して起動"
                                   FontSize="11" Foreground="#888888"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Multi-Instance Launch -->
                <Button Grid.Column="2"
                        Command="{Binding LaunchMultipleCommand}"
                        IsEnabled="{Binding !IsLaunching}"
                        HorizontalAlignment="Stretch"
                        Padding="0,20"
                        CornerRadius="10"
                        Background="#141414">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource IconMulti}" Width="22" Height="22"
                                  Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                        <TextBlock Text="マルチ起動" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                        <TextBlock Text="複数インスタンス同時起動"
                                   FontSize="11" Foreground="#888888"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Quick Actions -->
            <Border Background="#141414" CornerRadius="12" Padding="20,16">
                <StackPanel Spacing="16">
                    <TextBlock Text="クイックアクション" FontSize="13" FontWeight="SemiBold"
                               Foreground="#888888"/>
                    <Grid ColumnDefinitions="*,12,*,12,*">
                        <!-- Hot Reload -->
                        <Button Grid.Column="0" Command="{Binding HotReloadFlagsCommand}"
                                Padding="12,10" CornerRadius="8" Background="#202020"
                                HorizontalAlignment="Stretch">
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <PathIcon Data="{StaticResource IconFlash}" Width="20" Height="20"
                                          Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                                <TextBlock Text="ホットリロード" FontSize="11"
                                           Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Performance -->
                        <Button Grid.Column="2" Padding="12,10" CornerRadius="8"
                                Background="#202020" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <PathIcon Data="{StaticResource IconStats}" Width="20" Height="20"
                                          Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                                <TextBlock Text="パフォーマンス" FontSize="11"
                                           Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Profile -->
                        <Button Grid.Column="4" Padding="12,10" CornerRadius="8"
                                Background="#202020" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <PathIcon Data="{StaticResource IconPackage}" Width="20" Height="20"
                                          Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                                <TextBlock Text="プロファイル" FontSize="11"
                                           Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Info Card -->
            <Border Background="#141414" CornerRadius="10" Padding="16,14">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconInfo}" Width="14" Height="14"
                                  Foreground="#888888"/>
                        <TextBlock Text="NexStrap について" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#888888"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" FontSize="13">
                        Fast Flags のホットリロードは Roblox 起動中でも次回ゲーム参加時に反映されます。
                        ブラウザ機能でゲームをプレイしながら動画視聴が可能です。
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
