<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             x:Class="NexStrap.Views.Pages.HomePage"
             x:DataType="vm:HomeViewModel"
             Background="#080808">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header: title + badges -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="24,20,24,0">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="NexStrap" FontSize="22" FontWeight="Bold"
                           Foreground="#FFFFFF"/>
                <TextBlock Text="{Binding RobloxVersion}"
                           FontSize="11" Foreground="#444444"
                           FontFamily="Consolas,monospace"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Bottom">
                <Border Background="#111111" CornerRadius="20" Padding="10,4"
                        BorderBrush="#1E1E1E" BorderThickness="1"
                        IsVisible="{Binding IsRobloxRunning}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Ellipse Width="5" Height="5" Fill="#4ADE80"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="実行中" FontSize="11" Foreground="#888888"/>
                    </StackPanel>
                </Border>
                <Border Background="#111111" CornerRadius="20" Padding="10,4"
                        BorderBrush="#1E1E1E" BorderThickness="1"
                        IsVisible="{Binding IsLaunching}">
                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                               Foreground="#555555"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Divider -->
        <Border Grid.Row="1" Height="1" Background="#141414"
                VerticalAlignment="Top" Margin="24,16,24,0"/>

        <!-- Launch button pinned to bottom -->
        <Button Grid.Row="2"
                Command="{Binding LaunchRobloxCommand}"
                IsEnabled="{Binding !IsLaunching}"
                HorizontalAlignment="Stretch"
                Margin="24,0,24,20"
                Padding="0,14" CornerRadius="10"
                Background="#FFFFFF">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <PathIcon Data="{StaticResource IconPlay}" Width="13" Height="13"
                          Foreground="#080808" VerticalAlignment="Center"/>
                <TextBlock Text="起動" FontSize="13" FontWeight="SemiBold"
                           Foreground="#080808" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

    </Grid>

</UserControl>
