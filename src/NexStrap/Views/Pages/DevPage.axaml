<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             x:Class="NexStrap.Views.Pages.DevPage"
             x:DataType="vm:DevViewModel"
             Background="Transparent">

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="24,20">

            <!-- Header -->
            <StackPanel Spacing="6" Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Developer" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <Border Background="#1A0A00" CornerRadius="6" Padding="8,3"
                            BorderBrush="#3A1A00" BorderThickness="1" VerticalAlignment="Center">
                        <TextBlock Text="AUTHOR ONLY" FontSize="10" FontWeight="Bold"
                                   Foreground="#FF6A00" FontFamily="Consolas,monospace"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="{Binding Author, StringFormat='Signed in as {0}'}"
                           FontSize="11" Foreground="{DynamicResource MutedBrush}" FontFamily="Consolas,monospace"/>
            </StackPanel>

            <!-- App Info -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,14">
                <StackPanel Spacing="10">
                    <TextBlock Text="App Info" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                    <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto" HorizontalAlignment="Stretch">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" FontSize="12" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppVersion}" FontSize="12" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas,monospace"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Memory Usage" FontSize="12" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MemoryUsage}" FontSize="12" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas,monospace"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Discord RPC" FontSize="12" Foreground="{DynamicResource SubtextBrush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DiscordStatus}" FontSize="12"
                                   Foreground="{DynamicResource TextBrush}" FontFamily="Consolas,monospace"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Data Stats -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,14">
                <StackPanel Spacing="10">
                    <TextBlock Text="Data" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                    <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Fast Flags" FontSize="12" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FastFlagCount, StringFormat='{}{0} flags'}" FontSize="12" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas,monospace"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Mods" FontSize="12" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ModCount, StringFormat='{}{0} mods'}" FontSize="12" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas,monospace"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Game History" FontSize="12" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HistoryCount, StringFormat='{}{0} entries'}" FontSize="12" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas,monospace"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Favorites" FontSize="12" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FavoriteCount, StringFormat='{}{0} games'}" FontSize="12" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas,monospace"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Cached UserID" FontSize="12" Foreground="{DynamicResource SubtextBrush}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CachedUserId}" FontSize="12" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas,monospace"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Paths -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,14">
                <StackPanel Spacing="10">
                    <TextBlock Text="Paths" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Data Folder" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <Grid ColumnDefinitions="*,8,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding DataDir}"
                                       FontSize="11" Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas,monospace"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Content="Open"
                                    Command="{Binding OpenDataFolderCommand}"
                                    Background="{DynamicResource ElevatedBg}" Foreground="{DynamicResource SubtextBrush}"
                                    FontSize="11" Padding="10,4" CornerRadius="7"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="settings.json" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <Grid ColumnDefinitions="*,8,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding SettingsPath}"
                                       FontSize="11" Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas,monospace"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Content="Open"
                                    Command="{Binding OpenSettingsFileCommand}"
                                    Background="{DynamicResource ElevatedBg}" Foreground="{DynamicResource SubtextBrush}"
                                    FontSize="11" Padding="10,4" CornerRadius="7"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="history.json" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <Grid ColumnDefinitions="*,8,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding HistoryPath}"
                                       FontSize="11" Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas,monospace"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Content="Open"
                                    Command="{Binding OpenHistoryFileCommand}"
                                    Background="{DynamicResource ElevatedBg}" Foreground="{DynamicResource SubtextBrush}"
                                    FontSize="11" Padding="10,4" CornerRadius="7"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Roblox Version Path" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding RobloxPath}"
                                   FontSize="11" Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas,monospace"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Refresh Data"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource SurfaceBg}" Foreground="{DynamicResource SubtextBrush}"
                        FontSize="12" Padding="14,8" CornerRadius="10"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
