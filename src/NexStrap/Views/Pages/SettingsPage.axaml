<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:helpers="using:NexStrap.Helpers"
             x:Class="NexStrap.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Background="Transparent">

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="24,20" helpers:AnimationHelper.StaggerChildren="True">

            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"
                       Foreground="#FFFFFF" Margin="0,0,0,2"/>

            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,12">
                <StackPanel Spacing="12">
                    <TextBlock Text="Performance" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgSub}"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="FPS Unlock" Foreground="#FFFFFF" FontSize="13"/>
                            <TextBlock Text="Apply flags for uncapped frame rate"
                                       Foreground="{DynamicResource FgSub}" FontSize="11"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding FpsUnlockEnabled}"
                                      OnContent="ON" OffContent="OFF"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Multi-threading" Foreground="#FFFFFF" FontSize="13"/>
                            <TextBlock Text="Tune scheduler flags for CPU thread utilization"
                                       Foreground="{DynamicResource FgSub}" FontSize="11"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding MultiThreadingEnabled}"
                                      OnContent="ON" OffContent="OFF"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Performance Overlay" Foreground="#FFFFFF" FontSize="13"/>
                            <TextBlock Text="Show FPS and memory usage while playing"
                                       Foreground="{DynamicResource FgSub}" FontSize="11"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowPerformanceOverlay}"
                                      OnContent="ON" OffContent="OFF"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,12">
                <StackPanel Spacing="12">
                    <TextBlock Text="Roblox" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgSub}"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Auto-update Roblox" Foreground="#FFFFFF" FontSize="13"/>
                            <TextBlock Text="Automatically install Roblox updates"
                                       Foreground="{DynamicResource FgSub}" FontSize="11"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoUpdateRoblox}"
                                      OnContent="ON" OffContent="OFF"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Fast Flags Hot Reload" Foreground="#FFFFFF" FontSize="13"/>
                            <TextBlock Text="Reload flags on launch and when needed"
                                       Foreground="{DynamicResource FgSub}" FontSize="11"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding HotReloadEnabled}"
                                      OnContent="ON" OffContent="OFF"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,12">
                <StackPanel Spacing="12">
                    <TextBlock Text="App" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgSub}"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Minimize to Tray" Foreground="#FFFFFF" FontSize="13"/>
                            <TextBlock Text="Close button sends app to system tray"
                                       Foreground="{DynamicResource FgSub}" FontSize="11"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding MinimizeToTray}"
                                      OnContent="ON" OffContent="OFF"/>
                    </Grid>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Browser Homepage" Foreground="#FFFFFF" FontSize="13"/>
                        <TextBox Text="{Binding BrowserHomepage}"
                                 Background="#080808" Foreground="#FFFFFF"
                                 BorderBrush="#2A2A2A" CornerRadius="10"
                                 Padding="12,7" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,10,Auto" Margin="0,4,0,0">
                <Button Grid.Column="0" Content="Reset to Defaults"
                        Command="{Binding ResetToDefaultsCommand}"
                        Background="{DynamicResource CardBg}" Foreground="{DynamicResource FgSub}" FontSize="12"
                        Padding="14,8" CornerRadius="10" HorizontalAlignment="Left"/>
                <Button Grid.Column="2" Content="Save"
                        Command="{Binding SaveCommand}"
                        Background="#FFFFFF" Foreground="#080808"
                        FontWeight="SemiBold" FontSize="12"
                        Padding="24,8" CornerRadius="10"/>
            </Grid>

            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource FgSub}" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,0,0,12"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
