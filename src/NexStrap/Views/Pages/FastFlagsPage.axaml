<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             x:Class="NexStrap.Views.Pages.FastFlagsPage"
             x:DataType="vm:FastFlagsViewModel"
             Background="#080808">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,28,32,16" Spacing="4">
            <TextBlock Text="Fast Flags" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF"/>
            <TextBlock Text="{Binding SavePath, StringFormat='保存先: {0}'}"
                       FontSize="11" Foreground="#2E2E2E" FontFamily="Consolas,monospace"
                       IsVisible="{Binding SavePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="Roblox が見つかりません" FontSize="12" Foreground="#505050"
                       IsVisible="{Binding SavePath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
        </StackPanel>

        <!-- Profile Bar -->
        <Border Grid.Row="1" Background="#141414" CornerRadius="12"
                Margin="32,0,32,10" Padding="14,10">
            <Grid ColumnDefinitions="Auto,12,*,12,Auto,8,Auto,8,Auto">
                <TextBlock Grid.Column="0" Text="プロファイル" FontSize="12"
                           Foreground="#505050" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="2" ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          DisplayMemberBinding="{Binding Name}"
                          Background="#202020" Foreground="#FFFFFF"
                          CornerRadius="8" MinWidth="120" FontSize="13"/>
                <TextBox Grid.Column="4" Text="{Binding NewProfileName}"
                         Watermark="新しい名前..." FontSize="12"
                         Background="#202020" Foreground="#FFFFFF"
                         BorderBrush="#2E2E2E" CornerRadius="8"
                         Padding="10,6" MinWidth="120"/>
                <Button Grid.Column="6" Content="保存"
                        Command="{Binding SaveAsProfileCommand}"
                        Background="#FFFFFF" Foreground="#080808"
                        FontSize="12" FontWeight="SemiBold"
                        Padding="14,6" CornerRadius="8"/>
                <Button Grid.Column="8" Content="削除"
                        Command="{Binding DeleteProfileCommand}"
                        Background="Transparent" Foreground="#505050"
                        FontSize="12" BorderBrush="#2E2E2E" BorderThickness="1"
                        Padding="14,6" CornerRadius="8"/>
            </Grid>
        </Border>

        <!-- Controls -->
        <Grid Grid.Row="2" Margin="32,0,32,14"
              ColumnDefinitions="*,12,Auto,12,Auto,12,Auto,12,Auto">
            <TextBox Grid.Column="0" Text="{Binding SearchText}"
                     Watermark="検索..." Background="#141414" BorderBrush="#2E2E2E"
                     Foreground="#FFFFFF" CornerRadius="12" Padding="14,10"/>
            <ComboBox Grid.Column="2" ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Background="#141414" Foreground="#FFFFFF"
                      CornerRadius="12" MinWidth="130"/>
            <Button Grid.Column="4" Content="プリセット"
                    Command="{Binding ApplyPresetsAsyncCommand}"
                    Background="#141414" Foreground="#CCCCCC"
                    Padding="16,10" CornerRadius="12"/>
            <Button Grid.Column="6" Command="{Binding HotReloadCommand}"
                    Background="#141414" Foreground="#CCCCCC"
                    Padding="16,10" CornerRadius="12">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource IconFlash}" Width="13" Height="13" Foreground="#CCCCCC"/>
                    <TextBlock Text="ホットリロード" FontSize="13"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="8" Command="{Binding SaveCommand}"
                    IsEnabled="{Binding !IsSaving}"
                    Background="#FFFFFF" Foreground="#080808"
                    Padding="20,10" CornerRadius="12">
                <TextBlock Text="保存" FontWeight="SemiBold" FontSize="13"/>
            </Button>
        </Grid>

        <!-- FPS Quick Control -->
        <Border Grid.Row="2" Background="#141414" CornerRadius="12"
                Margin="32,52,32,0" Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto,16,Auto">
                <TextBlock Grid.Column="0" Text="FPS 上限" Foreground="#888888"
                           VerticalAlignment="Center" Margin="0,0,16,0" FontSize="13"/>
                <Slider Grid.Column="1" Minimum="30" Maximum="360"
                        Value="{Binding FpsTarget}" TickFrequency="30" IsSnapToTickEnabled="True"/>
                <TextBlock Grid.Column="2" Text="{Binding FpsTarget}"
                           Foreground="#FFFFFF" FontWeight="Bold" Width="44"
                           VerticalAlignment="Center" Margin="12,0" FontSize="14"/>
                <Button Grid.Column="4" Content="適用"
                        Command="{Binding SetFpsTargetCommand}"
                        Background="#202020" Foreground="#FFFFFF"
                        Padding="16,8" CornerRadius="10"/>
            </Grid>
        </Border>

        <!-- Flags List -->
        <Border Grid.Row="3" Margin="32,72,32,0" Background="#141414" CornerRadius="14">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="#202020" CornerRadius="16,16,0,0">
                    <Grid ColumnDefinitions="*,200,100,40" Margin="20,12">
                        <TextBlock Grid.Column="0" Text="フラグ名" FontSize="11" FontWeight="SemiBold" Foreground="#505050"/>
                        <TextBlock Grid.Column="1" Text="値" FontSize="11" FontWeight="SemiBold" Foreground="#505050"/>
                        <TextBlock Grid.Column="2" Text="カテゴリ" FontSize="11" FontWeight="SemiBold" Foreground="#505050"/>
                    </Grid>
                </Border>
                <ListBox Grid.Row="1" ItemsSource="{Binding Flags}"
                         SelectedItem="{Binding SelectedFlag}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:FlagEntry">
                            <Grid ColumnDefinitions="*,200,100,40" Margin="0,3">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="8,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#CCCCCC"
                                               FontFamily="Consolas,Courier New,monospace"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#505050"
                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding Value}"
                                         Background="#080808" Foreground="#FFFFFF"
                                         BorderBrush="#2E2E2E" Padding="10,6"
                                         CornerRadius="8" FontFamily="Consolas,Courier New,monospace"
                                         FontSize="13" Margin="4,2"/>
                                <Border Grid.Column="2" Background="#202020" CornerRadius="10"
                                        Padding="10,4" Margin="4,0" VerticalAlignment="Center"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="#888888"/>
                                </Border>
                                <Button Grid.Column="3"
                                        Command="{Binding $parent[UserControl].((vm:FastFlagsViewModel)DataContext).RemoveFlagAsyncCommand}"
                                        CommandParameter="{Binding}"
                                        Padding="4,4" Background="Transparent" Foreground="#505050" CornerRadius="6">
                                    <TextBlock Text="✕" FontSize="12"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Add Flag + Status -->
        <Grid Grid.Row="4" Margin="32,12,32,20" ColumnDefinitions="*,10,120,10,70,*,Auto">
            <TextBox Grid.Column="0" Text="{Binding NewFlagName}"
                     Watermark="新しいフラグ名 (例: FFlagXxx)"
                     Background="#141414" Foreground="#FFFFFF"
                     BorderBrush="#2E2E2E" CornerRadius="12" Padding="14,10"/>
            <TextBox Grid.Column="2" Text="{Binding NewFlagValue}" Watermark="値"
                     Background="#141414" Foreground="#FFFFFF"
                     BorderBrush="#2E2E2E" CornerRadius="12" Padding="14,10"/>
            <Button Grid.Column="4" Content="+ 追加"
                    Command="{Binding AddFlagAsyncCommand}"
                    Background="#FFFFFF" Foreground="#080808" FontWeight="SemiBold"
                    Padding="0,10" CornerRadius="12" HorizontalAlignment="Stretch"/>
            <TextBlock Grid.Column="6" Text="{Binding StatusMessage}"
                       Foreground="{Binding IsStatusError, Converter={StaticResource BoolToStringConverter}, ConverterParameter='#FF6B6B,#888888'}"
                       VerticalAlignment="Center"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </Grid>
    </Grid>
</UserControl>
