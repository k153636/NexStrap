<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             x:Class="NexStrap.Views.Pages.FastFlagsPage"
             x:DataType="vm:FastFlagsViewModel"
             Background="Transparent">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="24,20,24,12" Spacing="3">
            <TextBlock Text="Fast Flags" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF"/>
            <TextBlock Text="Fine-tune Roblox's internal settings for better performance"
                       FontSize="11" Foreground="{DynamicResource FgSub}"
                       IsVisible="{Binding SavePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="Roblox not found — launch Roblox once to enable tweaks"
                       FontSize="11" Foreground="{DynamicResource MutedBrush}"
                       IsVisible="{Binding SavePath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="24,0,24,10"
              ColumnDefinitions="*,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto">

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText}"
                     Watermark="Search flags..."
                     Background="{DynamicResource SurfaceBg}" Foreground="#FFFFFF"
                     BorderBrush="#2E2E2E" CornerRadius="8" Padding="12,7" FontSize="12"/>

            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Background="{DynamicResource SurfaceBg}" Foreground="#FFFFFF"
                      CornerRadius="8" MinWidth="110" FontSize="12"/>

            <Button Grid.Column="4" Content="Presets"
                    Command="{Binding OpenPresetWindowCommand}"
                    Background="{DynamicResource SurfaceBg}" Foreground="{DynamicResource TextBrush}"
                    FontSize="12" Padding="12,7" CornerRadius="8"/>

            <Button Grid.Column="6" Content="Bulk Import"
                    Command="{Binding OpenBulkImportWindowCommand}"
                    Background="{DynamicResource SurfaceBg}" Foreground="{DynamicResource TextBrush}"
                    FontSize="12" Padding="12,7" CornerRadius="8"/>

            <Button Grid.Column="8" Content="+ Add"
                    Command="{Binding OpenAddFlagWindowCommand}"
                    Background="{DynamicResource SurfaceBg}" Foreground="{DynamicResource TextBrush}"
                    FontSize="12" Padding="12,7" CornerRadius="8"/>

            <Button Grid.Column="10" Content="Profiles"
                    Command="{Binding OpenProfileManagerCommand}"
                    Background="{DynamicResource SurfaceBg}" Foreground="{DynamicResource TextBrush}"
                    FontSize="12" Padding="12,7" CornerRadius="8"/>

            <Button Grid.Column="12" Command="{Binding HotReloadCommand}"
                    IsEnabled="{Binding !IsSaving}"
                    Background="#FFFFFF" Foreground="#080808"
                    Padding="12,7" CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <PathIcon Data="{StaticResource IconFlash}" Width="11" Height="11" Foreground="#080808"/>
                    <TextBlock Text="Save" FontWeight="SemiBold" FontSize="12"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Flags list -->
        <Border Grid.Row="2" Margin="24,0,24,14"
                Background="{DynamicResource SurfaceBg}" CornerRadius="8">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Column header -->
                <Border Grid.Row="0" Background="{DynamicResource ElevatedBg}"
                        CornerRadius="8,8,0,0">
                    <Grid ColumnDefinitions="*,200,100,40" Margin="16,8">
                        <TextBlock Grid.Column="0" Text="Flag Name" FontSize="11"
                                   FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Grid.Column="1" Text="Value" FontSize="11"
                                   FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Grid.Column="2" Text="Category" FontSize="11"
                                   FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                    </Grid>
                </Border>

                <!-- Flag rows -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Flags}"
                         SelectedItem="{Binding SelectedFlag}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:FlagEntry">
                            <Grid ColumnDefinitions="*,200,100,40" Margin="0,2">
                                <StackPanel Grid.Column="0" Spacing="1" Margin="8,0">
                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontFamily="Consolas,Courier New,monospace"/>
                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                               Foreground="{DynamicResource MutedBrush}"
                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding Value}"
                                         Background="#080808" Foreground="#FFFFFF"
                                         BorderBrush="#2E2E2E" Padding="8,5"
                                         CornerRadius="8" FontFamily="Consolas,Courier New,monospace"
                                         FontSize="12" Margin="4,2"/>
                                <Border Grid.Column="2" Background="{DynamicResource ElevatedBg}"
                                        CornerRadius="8" Padding="8,3" Margin="4,0"
                                        VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Category}" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}"/>
                                </Border>
                                <Button Grid.Column="3"
                                        Command="{Binding DeleteCommand}"
                                        Padding="4,4" Background="Transparent"
                                        Foreground="{DynamicResource MutedBrush}" CornerRadius="4">
                                    <TextBlock Text="✕" FontSize="11"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Status bar -->
                <Border Grid.Row="2" Padding="16,6"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{Binding IsStatusError,
                                   Converter={StaticResource BoolToColorConverter},
                                   ConverterParameter='#FF6B6B,#888888'}"
                               FontSize="11"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
