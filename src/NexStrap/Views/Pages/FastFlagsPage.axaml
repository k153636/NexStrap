<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             x:Class="NexStrap.Views.Pages.FastFlagsPage"
             x:DataType="vm:FastFlagsViewModel"
             Background="Transparent">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="24,20,24,12" Spacing="3">
            <TextBlock Text="Fast Flags" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF"/>
            <TextBlock Text="Fine-tune Roblox's internal settings for better performance"
                       FontSize="11" Foreground="{DynamicResource FgSub}"
                       IsVisible="{Binding SavePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="Roblox not found — launch Roblox once to enable tweaks"
                       FontSize="11" Foreground="{DynamicResource MutedBrush}"
                       IsVisible="{Binding SavePath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
        </StackPanel>

        <!-- Flags list — full remaining height -->
        <Border Grid.Row="1" Margin="24,0,24,14"
                Background="{DynamicResource SurfaceBg}" CornerRadius="8">
            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Toolbar -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource ElevatedBg}" BorderThickness="0,0,0,1"
                        Padding="12,10">
                    <Grid ColumnDefinitions="*,6,Auto">

                        <TextBox Grid.Column="0"
                                 Text="{Binding SearchText}"
                                 Watermark="Search flags..."
                                 Background="{DynamicResource ElevatedBg}" Foreground="#FFFFFF"
                                 BorderBrush="Transparent" CornerRadius="8" Padding="12,7" FontSize="12"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">

                            <Button Content="Presets"
                                    Command="{Binding OpenPresetWindowCommand}"
                                    Background="{DynamicResource ElevatedBg}" Foreground="{DynamicResource TextBrush}"
                                    FontSize="12" Padding="12,7" CornerRadius="8"/>

                            <Button Content="Bulk Import"
                                    Command="{Binding OpenBulkImportWindowCommand}"
                                    Background="{DynamicResource ElevatedBg}" Foreground="{DynamicResource TextBrush}"
                                    FontSize="12" Padding="12,7" CornerRadius="8"/>

                            <Button Content="+ Add"
                                    Command="{Binding OpenAddFlagWindowCommand}"
                                    Background="{DynamicResource ElevatedBg}" Foreground="{DynamicResource TextBrush}"
                                    FontSize="12" Padding="12,7" CornerRadius="8"/>

                            <Button Content="Profiles"
                                    Command="{Binding OpenProfileManagerCommand}"
                                    Background="{DynamicResource ElevatedBg}" Foreground="{DynamicResource TextBrush}"
                                    FontSize="12" Padding="12,7" CornerRadius="8"/>

                            <Button Command="{Binding HotReloadCommand}"
                                    IsEnabled="{Binding !IsSaving}"
                                    Background="#FFFFFF" Foreground="#080808"
                                    Padding="12,7" CornerRadius="8">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <PathIcon Data="{StaticResource IconFlash}" Width="11" Height="11" Foreground="#080808"/>
                                    <TextBlock Text="Save" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Column header -->
                <Border Grid.Row="1" Background="{DynamicResource ElevatedBg}" Padding="16,7">
                    <Grid ColumnDefinitions="*,175,135,40">
                        <TextBlock Grid.Column="0" Text="FLAG NAME" FontSize="10"
                                   FontWeight="SemiBold" Foreground="#38FFFFFF" LetterSpacing="1"/>
                        <TextBlock Grid.Column="1" Text="VALUE" FontSize="10"
                                   FontWeight="SemiBold" Foreground="#38FFFFFF" LetterSpacing="1"/>
                        <TextBlock Grid.Column="2" Text="CATEGORY" FontSize="10"
                                   FontWeight="SemiBold" Foreground="#38FFFFFF" LetterSpacing="1"/>
                    </Grid>
                </Border>

                <!-- Flag rows -->
                <ListBox Grid.Row="2" ItemsSource="{Binding Flags}"
                         SelectedItem="{Binding SelectedFlag}"
                         Background="Transparent" BorderThickness="0"
                         Padding="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#09FFFFFF"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0DFFFFFF"/>
                        </Style>
                        <Style Selector="Button.flag-delete">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#30FFFFFF"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style Selector="Button.flag-delete:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#18FF4444"/>
                        </Style>
                        <Style Selector="Button.flag-delete:pointerover">
                            <Setter Property="Foreground" Value="#FF6B6B"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:FlagEntry">
                            <Border BorderBrush="#08FFFFFF" BorderThickness="0,0,0,1"
                                    Padding="16,9,12,9">
                                <Grid ColumnDefinitions="*,175,135,40">

                                    <!-- Flag Name + Description -->
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center"
                                                Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   FontWeight="Medium"
                                                   Foreground="#EEFFFFFF"
                                                   FontFamily="Consolas,Courier New,monospace"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="#48FFFFFF"
                                                   IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Value -->
                                    <TextBox Grid.Column="1" Text="{Binding Value}"
                                             Background="#0FFFFFFF" Foreground="#E5FFFFFF"
                                             BorderBrush="#16FFFFFF" BorderThickness="1"
                                             Padding="10,5" CornerRadius="6"
                                             FontFamily="Consolas,Courier New,monospace"
                                             FontSize="12" Margin="0,0,10,0"
                                             VerticalAlignment="Center"/>

                                    <!-- Category pill -->
                                    <Border Grid.Column="2"
                                            CornerRadius="20" Padding="10,4"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center" HorizontalAlignment="Left"
                                            Background="#10FFFFFF">
                                        <TextBlock Text="{Binding Category}" FontSize="10"
                                                   FontWeight="Medium"
                                                   Foreground="#60FFFFFF"/>
                                    </Border>

                                    <!-- Delete button -->
                                    <Button Grid.Column="3"
                                            Classes="flag-delete"
                                            Command="{Binding DeleteCommand}"
                                            Padding="7,7" CornerRadius="6"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <PathIcon Width="8" Height="8"
                                                  Data="M8,1.41 L6.59,0 L4,2.59 L1.41,0 L0,1.41 L2.59,4 L0,6.59 L1.41,8 L4,5.41 L6.59,8 L8,6.59 L5.41,4 Z"/>
                                    </Button>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Status bar -->
                <Border Grid.Row="3" Padding="16,6"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{Binding IsStatusError,
                                   Converter={StaticResource BoolToColorConverter},
                                   ConverterParameter='#FF6B6B,#888888'}"
                               FontSize="11"/>
                </Border>

            </Grid>
        </Border>

    </Grid>
</UserControl>
