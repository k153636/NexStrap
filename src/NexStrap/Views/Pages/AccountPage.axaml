<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexStrap.ViewModels"
             xmlns:helpers="using:NexStrap.Helpers"
             x:Class="NexStrap.Views.Pages.AccountPage"
             x:DataType="vm:AccountViewModel"
             Background="Transparent">

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="24,20" helpers:AnimationHelper.StaggerChildren="True">

            <TextBlock Text="Account" FontSize="22" FontWeight="Bold"
                       Foreground="#FFFFFF" Margin="0,0,0,2"/>

            <!-- Import section -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,14"
                    BoxShadow="0 2 10 0 #22000000">
                <StackPanel Spacing="10">
                    <TextBlock Text="Import from Chrome" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgSub}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Import from Chrome"
                                Command="{Binding ImportFromChromeCommand}"
                                IsEnabled="{Binding IsImporting, Converter={x:Static BoolConverters.Not}}"
                                Background="{DynamicResource OverlayBg}" Foreground="#FFFFFF"
                                FontSize="12" Padding="14,8" CornerRadius="10"/>
                        <Button Content="Cancel"
                                Command="{Binding CancelImportCommand}"
                                IsVisible="{Binding IsImporting}"
                                Background="#1AFF4444" Foreground="{DynamicResource FgDanger}"
                                FontSize="12" Padding="14,8" CornerRadius="10"/>
                    </StackPanel>
                    <TextBlock Text="Please log in to roblox.com in Chrome…"
                               FontSize="12" Foreground="{DynamicResource SubtextBrush}"
                               IsVisible="{Binding IsWaitingForLogin}"/>
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <TextBlock Text="No accounts added"
                       FontSize="12" Foreground="{DynamicResource FgMuted}"
                       HorizontalAlignment="Center" Margin="0,16,0,0"
                       IsVisible="{Binding Accounts.Count,
                           Converter={StaticResource IntToZeroConverter}}"/>

            <!-- Accounts list -->
            <ItemsControl ItemsSource="{Binding Accounts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AccountEntryViewModel">
                        <Border Background="{DynamicResource CardBg}" CornerRadius="10" Padding="12,10"
                                Margin="0,0,0,6" BoxShadow="0 2 8 0 #1A000000">
                            <Grid ColumnDefinitions="36,*,Auto">

                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="36" Height="36"
                                        CornerRadius="18" ClipToBounds="True"
                                        Background="{DynamicResource OverlayBg}">
                                    <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                </Border>

                                <!-- Name / username -->
                                <StackPanel Grid.Column="1" Spacing="2" Margin="10,0">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                        <Border CornerRadius="6" Padding="6,2"
                                                Background="#1A4ADE80"
                                                IsVisible="{Binding IsActive}">
                                            <TextBlock Text="Active" FontSize="10"
                                                       Foreground="#4ADE80"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource FgSub}"
                                               Text="{Binding Username, StringFormat='@{0}'}"/>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center">
                                    <Button Content="Switch"
                                            Command="{Binding $parent[ItemsControl].((vm:AccountViewModel)DataContext).SetActiveCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource OverlayBg}"
                                            Foreground="#FFFFFF" FontSize="11"
                                            Padding="10,5" CornerRadius="8"/>
                                    <Button Content="Remove"
                                            Command="{Binding $parent[ItemsControl].((vm:AccountViewModel)DataContext).RemoveCommand}"
                                            CommandParameter="{Binding}"
                                            Background="#1AFF4444"
                                            Foreground="{DynamicResource FgDanger}" FontSize="11"
                                            Padding="10,5" CornerRadius="8"/>
                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Status message -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource FgSub}" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,4,0,12"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
