<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NexStrap.Views.Pages.BrowserPage"
             Background="#080808">

    <ScrollViewer>
        <StackPanel Spacing="20" Margin="32,28">

            <!-- Header -->
            <StackPanel Spacing="6">
                <TextBlock Text="ブラウザ" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF"/>
                <TextBlock Text="ゲームをプレイしながら好きなサイトを開きましょう"
                           FontSize="14" Foreground="#505050"/>
            </StackPanel>

            <!-- URL Bar -->
            <Grid ColumnDefinitions="*,12,Auto">
                <TextBox Grid.Column="0" x:Name="UrlBar"
                         Background="#141414" Foreground="#FFFFFF"
                         BorderBrush="#2E2E2E" CornerRadius="14"
                         Padding="18,13" FontSize="14"
                         Watermark="URL を入力... (例: https://youtube.com)"/>
                <Button Grid.Column="2" x:Name="GoButton"
                        Padding="20,13" CornerRadius="14"
                        Background="#FFFFFF" Foreground="#080808">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <PathIcon Data="{StaticResource IconGlobe}" Width="14" Height="14" Foreground="#080808"/>
                        <TextBlock Text="ブラウザで開く" FontWeight="SemiBold" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Quick Links -->
            <StackPanel Spacing="16">
                <TextBlock Text="クイックリンク" FontSize="12" FontWeight="SemiBold"
                           Foreground="#505050" Margin="4,0"/>
                <WrapPanel Orientation="Horizontal">

                    <Button x:Name="YoutubeButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="#141414">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPlay}" Width="26" Height="26"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="YouTube" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="動画・アニメを視聴" FontSize="11"
                                           Foreground="#505050" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NicoButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="#141414">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconVideo}" Width="26" Height="26"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="ニコニコ" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="動画・生放送" FontSize="11"
                                           Foreground="#505050" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TwitterButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="#141414">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconChat}" Width="26" Height="26"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="X (Twitter)" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="タイムライン" FontSize="11"
                                           Foreground="#505050" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="DiscordButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="#141414">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconChat}" Width="26" Height="26"
                                      Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="Discord" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="フレンドとチャット" FontSize="11"
                                           Foreground="#505050" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SpotifyButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="#141414">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconMusic}" Width="26" Height="26"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="Spotify" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="音楽を聴きながら" FontSize="11"
                                           Foreground="#505050" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="RobloxButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="#141414">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconGlobe}" Width="26" Height="26"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="Roblox.com" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="ゲームを探す" FontSize="11"
                                           Foreground="#505050" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                </WrapPanel>
            </StackPanel>

            <!-- Tip -->
            <Border Background="#141414" CornerRadius="16" Padding="24,20">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconInfo}" Width="13" Height="13"
                                  Foreground="#505050"/>
                        <TextBlock Text="使い方のヒント" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#505050"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="#888888" FontSize="13" LineHeight="22">
                        ブラウザで開いたサイトは Roblox と並べて表示できます。
                        Windows キー + ← / → でスナップして、片方でゲーム・もう片方で動画を再生しましょう。
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
