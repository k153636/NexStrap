<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NexStrap.Views.Pages.BrowserPage"
             Background="#080808">

    <ScrollViewer>
        <StackPanel Spacing="24" Margin="32,28">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="ブラウザ" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"/>
                <TextBlock Text="ゲームをプレイしながら好きなサイトを開きましょう"
                           FontSize="13" Foreground="#888888"/>
            </StackPanel>

            <!-- URL Bar -->
            <Grid ColumnDefinitions="*,12,Auto">
                <TextBox Grid.Column="0" x:Name="UrlBar"
                         Background="#141414" Foreground="#FFFFFF"
                         BorderBrush="#2E2E2E" CornerRadius="8"
                         Padding="14,10" FontSize="14"
                         Watermark="URL を入力... (例: https://youtube.com)"/>
                <Button Grid.Column="2" x:Name="GoButton"
                        Padding="16,10" CornerRadius="8"
                        Background="#FFFFFF" Foreground="#080808">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource IconGlobe}" Width="14" Height="14" Foreground="#080808"/>
                        <TextBlock Text="ブラウザで開く" FontWeight="SemiBold" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Quick Links -->
            <StackPanel Spacing="12">
                <TextBlock Text="クイックリンク" FontSize="13" FontWeight="SemiBold"
                           Foreground="#888888"/>
                <WrapPanel Orientation="Horizontal">

                    <Button x:Name="YoutubeButton" Margin="0,0,12,12"
                            Padding="20,16" CornerRadius="10" Background="#141414">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPlay}" Width="28" Height="28"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <TextBlock Text="YouTube" FontSize="13" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="動画・アニメを視聴" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NicoButton" Margin="0,0,12,12"
                            Padding="20,16" CornerRadius="10" Background="#141414">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconVideo}" Width="28" Height="28"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <TextBlock Text="ニコニコ動画" FontSize="13" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="動画・生放送" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TwitterButton" Margin="0,0,12,12"
                            Padding="20,16" CornerRadius="10" Background="#141414">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconChat}" Width="28" Height="28"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <TextBlock Text="X (Twitter)" FontSize="13" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="タイムラインを確認" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="DiscordButton" Margin="0,0,12,12"
                            Padding="20,16" CornerRadius="10" Background="#141414">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconChat}" Width="28" Height="28"
                                      Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="Discord" FontSize="13" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="フレンドとチャット" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SpotifyButton" Margin="0,0,12,12"
                            Padding="20,16" CornerRadius="10" Background="#141414">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconMusic}" Width="28" Height="28"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <TextBlock Text="Spotify" FontSize="13" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="音楽を聴きながら" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="RobloxButton" Margin="0,0,12,12"
                            Padding="20,16" CornerRadius="10" Background="#141414">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconGlobe}" Width="28" Height="28"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <TextBlock Text="Roblox.com" FontSize="13" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="ゲームを探す" FontSize="11"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </WrapPanel>
            </StackPanel>

            <!-- Tip -->
            <Border Background="#141414" CornerRadius="10" Padding="16,12">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconInfo}" Width="14" Height="14"
                                  Foreground="#888888"/>
                        <TextBlock Text="使い方のヒント" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#888888"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" FontSize="13">
                        ブラウザで開いたサイトは Roblox と並べて表示できます。
                        Windows キー + ← / → でウィンドウをスナップして、片方でゲーム・もう片方で動画を再生しましょう。
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
