<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NexStrap.Views.Pages.BrowserPage"
             Background="Transparent">

    <ScrollViewer>
        <StackPanel Spacing="20" Margin="32,28">

            <!-- Header -->
            <StackPanel Spacing="6">
                <TextBlock Text="Browser" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF"/>
                <TextBlock Text="Open your favorite sites while playing Roblox"
                           FontSize="14" Foreground="{DynamicResource MutedBrush}"/>
            </StackPanel>

            <!-- URL Bar -->
            <Grid ColumnDefinitions="*,12,Auto">
                <TextBox Grid.Column="0" x:Name="UrlBar"
                         Background="{DynamicResource SurfaceBg}" Foreground="#FFFFFF"
                         BorderBrush="#2E2E2E" CornerRadius="14"
                         Padding="18,13" FontSize="14"
                         Watermark="Enter URL... (e.g. https://youtube.com)"/>
                <Button Grid.Column="2" x:Name="GoButton"
                        Padding="20,13" CornerRadius="14"
                        Background="#FFFFFF" Foreground="#080808">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <PathIcon Data="{StaticResource IconGlobe}" Width="14" Height="14" Foreground="#080808"/>
                        <TextBlock Text="Open in Browser" FontWeight="SemiBold" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Quick Links -->
            <StackPanel Spacing="16">
                <TextBlock Text="Quick Links" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedBrush}" Margin="4,0"/>
                <WrapPanel Orientation="Horizontal">

                    <Button x:Name="YoutubeButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="{DynamicResource SurfaceBg}">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPlay}" Width="26" Height="26"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="YouTube" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="Watch videos &amp; anime" FontSize="11"
                                           Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NicoButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="{DynamicResource SurfaceBg}">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconVideo}" Width="26" Height="26"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="Niconico" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="Videos &amp; livestreams" FontSize="11"
                                           Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TwitterButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="{DynamicResource SurfaceBg}">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconChat}" Width="26" Height="26"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="X (Twitter)" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="Timeline" FontSize="11"
                                           Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="DiscordButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="{DynamicResource SurfaceBg}">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconChat}" Width="26" Height="26"
                                      Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="Discord" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="Chat with friends" FontSize="11"
                                           Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SpotifyButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="{DynamicResource SurfaceBg}">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconMusic}" Width="26" Height="26"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="Spotify" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="Listen while you play" FontSize="11"
                                           Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button x:Name="RobloxButton" Margin="0,0,12,12"
                            Padding="24,20" CornerRadius="18" Background="{DynamicResource SurfaceBg}">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconGlobe}" Width="26" Height="26"
                                      Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Spacing="3" HorizontalAlignment="Center">
                                <TextBlock Text="Roblox.com" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="Browse games" FontSize="11"
                                           Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                </WrapPanel>
            </StackPanel>

            <!-- Tip -->
            <Border Background="{DynamicResource SurfaceBg}" CornerRadius="16" Padding="24,20">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconInfo}" Width="13" Height="13"
                                  Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="Tip" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedBrush}"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SubtextBrush}" FontSize="13" LineHeight="22">
                        You can snap browser windows alongside Roblox.
                        Use Win + ← / → to snap — game on one side, video on the other.
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
