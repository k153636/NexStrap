<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels.Installer"
        x:Class="NexStrap.Views.Installer.InstallerWindow"
        x:DataType="vm:InstallerViewModel"
        Title="NexStrap Setup"
        Width="580" Height="400"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#080808"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Grid RowDefinitions="30,*,56">

        <!-- Title bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" IsHitTestVisible="False">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0" Spacing="7"
                        VerticalAlignment="Center">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="14" Height="14" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                <TextBlock Text="NexStrap Setup" FontSize="12" FontWeight="SemiBold"
                           Foreground="#888888" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Content area -->
        <Border Grid.Row="1" Margin="24,4,24,0">
            <Grid>
                <!-- Welcome Step -->
                <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center"
                      IsVisible="{Binding Step,
                          Converter={x:Static ObjectConverters.Equal},
                          ConverterParameter={x:Static vm:InstallerStep.Welcome}}">

                    <!-- Left: logo -->
                    <Image Grid.Column="0" Source="avares://NexStrap/Assets/nexstrap.png"
                           Width="72" Height="72" Margin="0,0,24,0"
                           RenderOptions.BitmapInterpolationMode="HighQuality"
                           VerticalAlignment="Center"/>

                    <!-- Right: text -->
                    <StackPanel Grid.Column="1" Spacing="14" VerticalAlignment="Center">
                        <StackPanel Spacing="3">
                            <TextBlock Text="NexStrap" FontSize="24" FontWeight="Bold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="{Binding AppVersion, Mode=OneWay}"
                                       FontSize="11" Foreground="#444444"
                                       FontFamily="Consolas,monospace"/>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#888888"
                                   LineHeight="20"
                                   Text="An open-source launcher that replaces the default Roblox client. Built for players who want full control over how Roblox runs on their PC."/>

                        <!-- Minimal icon pills -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#141414" CornerRadius="6" Padding="8,5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource IconFlash}"
                                              Width="11" Height="11" Foreground="#666666"/>
                                    <TextBlock Text="Performance" FontSize="11" Foreground="#666666"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#141414" CornerRadius="6" Padding="8,5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource IconSettings}"
                                              Width="11" Height="11" Foreground="#666666"/>
                                    <TextBlock Text="Customization" FontSize="11" Foreground="#666666"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#141414" CornerRadius="6" Padding="8,5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource IconGlobe}"
                                              Width="11" Height="11" Foreground="#666666"/>
                                    <TextBlock Text="Web Launch" FontSize="11" Foreground="#666666"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Install Step -->
                <StackPanel Spacing="14" IsVisible="{Binding Step,
                                Converter={x:Static ObjectConverters.Equal},
                                ConverterParameter={x:Static vm:InstallerStep.Install}}">
                    <TextBlock Text="Install" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF"/>

                    <!-- Install location -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Installation Location" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#888888"/>
                        <Grid ColumnDefinitions="*,8,Auto,6,Auto">
                            <TextBox Grid.Column="0" Text="{Binding InstallPath}"
                                     Background="#111111" Foreground="#FFFFFF"
                                     BorderBrush="{Binding PathError,
                                         Converter={StaticResource BoolToColorConverter},
                                         ConverterParameter='#FF4444,#2A2A2A'}"
                                     BorderThickness="1" CornerRadius="8"
                                     Padding="10,6" FontSize="12" FontFamily="Consolas,monospace"/>
                            <Button Grid.Column="2" Content="Browse"
                                    Command="{Binding BrowseCommand}"
                                    Background="#1A1A1A" Foreground="#888888"
                                    FontSize="12" Padding="12,6" CornerRadius="8"/>
                            <Button Grid.Column="4" Content="Default"
                                    Command="{Binding ResetPathCommand}"
                                    Background="#1A1A1A" Foreground="#888888"
                                    FontSize="12" Padding="12,6" CornerRadius="8"/>
                        </Grid>
                        <TextBlock Text="{Binding PathErrorMessage}"
                                   FontSize="11" Foreground="#FF6B6B"
                                   IsVisible="{Binding PathError}"/>
                    </StackPanel>

                    <!-- Shortcuts -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Shortcuts" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#888888"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Desktop shortcut"
                                       Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding DesktopShortcut}"
                                          OnContent="ON" OffContent="OFF"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Start Menu shortcut"
                                       Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartMenuShortcut}"
                                          OnContent="ON" OffContent="OFF"/>
                        </Grid>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="11" Foreground="#4ADE80"
                               IsVisible="{Binding StatusMessage,
                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>

                <!-- Complete Step -->
                <StackPanel Spacing="20" VerticalAlignment="Center"
                            IsVisible="{Binding Step,
                                Converter={x:Static ObjectConverters.Equal},
                                ConverterParameter={x:Static vm:InstallerStep.Complete}}">
                    <TextBlock Text="Installation Complete" FontSize="22" FontWeight="Bold"
                               Foreground="#FFFFFF"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#888888"
                               Text="NexStrap has been installed successfully. You can now launch it from the desktop shortcut or Start Menu."/>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Launch NexStrap"
                                Command="{Binding LaunchInstalledCommand}"
                                Background="#FFFFFF" Foreground="#080808"
                                FontSize="13" FontWeight="SemiBold"
                                Padding="20,10" CornerRadius="8"/>
                        <Button Content="Close"
                                Command="{Binding CloseInstallerCommand}"
                                Background="#1A1A1A" Foreground="#888888"
                                FontSize="13" Padding="20,10" CornerRadius="8"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom button bar -->
        <Border Grid.Row="2" BorderBrush="#1A1A1A" BorderThickness="0,1,0,0"
                Padding="24,0">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Progress indicator (dots) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding Step,
                                Converter={StaticResource BoolToColorConverter},
                                ConverterParameter='#FFFFFF,#333333'}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="6" Height="6" Fill="#333333" VerticalAlignment="Center"/>
                    <Ellipse Width="6" Height="6" Fill="#333333" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <!-- Back -->
                    <Button Content="← Back"
                            Command="{Binding BackCommand}"
                            Background="#1A1A1A" Foreground="#888888"
                            FontSize="12" Padding="16,8" CornerRadius="8"
                            IsVisible="{Binding Step,
                                Converter={x:Static ObjectConverters.Equal},
                                ConverterParameter={x:Static vm:InstallerStep.Install}}"/>

                    <!-- Next (Welcome) -->
                    <Button Content="Next →"
                            Command="{Binding NextCommand}"
                            Background="#FFFFFF" Foreground="#080808"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="20,8" CornerRadius="8"
                            IsVisible="{Binding Step,
                                Converter={x:Static ObjectConverters.Equal},
                                ConverterParameter={x:Static vm:InstallerStep.Welcome}}"/>

                    <!-- Install (Install step) -->
                    <Button Content="Install"
                            Command="{Binding InstallCommand}"
                            IsEnabled="{Binding IsInstalling,
                                Converter={x:Static BoolConverters.Not}}"
                            Background="#FFFFFF" Foreground="#080808"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="20,8" CornerRadius="8"
                            IsVisible="{Binding Step,
                                Converter={x:Static ObjectConverters.Equal},
                                ConverterParameter={x:Static vm:InstallerStep.Install}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
