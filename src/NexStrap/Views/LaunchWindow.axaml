<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.LaunchWindow"
        x:DataType="vm:LaunchWindowViewModel"
        Title="NexStrap"
        Icon="avares://NexStrap/Assets/nexstrap.png"
        Width="780" Height="372"
        MinWidth="780" MinHeight="372"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="0">

    <Grid RowDefinitions="28,*">
        <Grid Grid.Row="0" Background="Transparent"
              PointerPressed="TitleBar_PointerPressed"
              DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="12,0" Spacing="7" IsHitTestVisible="False">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="16" Height="16"/>
                <TextBlock Text="NexStrap"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="12,8,12,12"
                Classes="area-panel"
                Padding="18">
            <Grid ColumnDefinitions="238,*">
                <StackPanel Margin="8,10,18,10"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <Border Width="84" Height="84"
                            CornerRadius="22"
                            Background="{DynamicResource SurfaceBg}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Image Source="avares://NexStrap/Assets/nexstrap.png"
                               Width="84" Height="84"
                               RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    </Border>

                    <StackPanel Margin="0,6,0,0" Spacing="4">
                        <TextBlock Text="NexStrap"
                                   FontSize="31"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"/>
                        <TextBlock Text="Roblox launcher"
                                   FontSize="12"
                                   Foreground="{DynamicResource FgSub}"/>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgMuted}"/>
                    </StackPanel>

                    <StackPanel Margin="0,10,0,0" Spacing="6">
                        <Button Classes="plain"
                                Command="{Binding OpenAboutCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconInfo}"
                                          Width="12" Height="12"
                                          Foreground="{DynamicResource FgSub}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="NexStrapについて"
                                           FontSize="12"
                                           Foreground="#4DA3FF"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="plain"
                                Command="{Binding OpenGitHubCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconGlobe}"
                                          Width="12" Height="12"
                                          Foreground="{DynamicResource FgSub}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="GitHub"
                                           FontSize="12"
                                           Foreground="#4DA3FF"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="plain"
                                Command="{Binding OpenDiscordCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconChat}"
                                          Width="12" Height="12"
                                          Foreground="{DynamicResource FgSub}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Discord"
                                           FontSize="12"
                                           Foreground="#4DA3FF"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Stretch"
                            Margin="0,8,0,8"
                            Spacing="9">
                    <Button Command="{Binding LaunchRobloxCommand}"
                            IsEnabled="{Binding IsLaunchingRoblox, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Stretch"
                            Background="#FFFFFF"
                            Foreground="#080808"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Height="54"
                            Padding="18,14"
                            CornerRadius="11">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPlay}"
                                      Width="15" Height="15"
                                      Foreground="#080808"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Launch Roblox"
                                       HorizontalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#080808"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="›"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#080808"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Command="{Binding LaunchStudioCommand}"
                            HorizontalAlignment="Stretch"
                            Background="{DynamicResource SurfaceBg}"
                            Foreground="{DynamicResource FgSub}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Height="48"
                            Padding="18,12"
                            CornerRadius="11">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconSettings}"
                                      Width="15" Height="15"
                                      Foreground="{DynamicResource FgSub}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Launch Roblox Studio"
                                       HorizontalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FgSub}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="›"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FgSub}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Stretch"
                            Background="{DynamicResource SurfaceBg}"
                            Foreground="{DynamicResource FgSub}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Height="48"
                            Padding="18,12"
                            CornerRadius="11">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconSettings}"
                                      Width="15" Height="15"
                                      Foreground="{DynamicResource FgSub}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Settings"
                                       HorizontalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FgSub}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="›"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FgSub}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Command="{Binding LaunchAppCommand}"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            Foreground="{DynamicResource FgMuted}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            FontSize="12"
                            Height="48"
                            Padding="18,12"
                            CornerRadius="11">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconInfo}"
                                      Width="15" Height="15"
                                      Foreground="{DynamicResource FgMuted}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Launch NexStrap"
                                       HorizontalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FgMuted}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="›"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FgMuted}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
