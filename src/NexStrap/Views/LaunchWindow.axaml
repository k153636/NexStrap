<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.LaunchWindow"
        x:DataType="vm:LaunchWindowViewModel"
        Title="NexStrap"
        Icon="avares://NexStrap/Assets/nexstrap.png"
        Width="{StaticResource LaunchWindowWidth}"
        Height="{StaticResource LaunchWindowHeight}"
        MinWidth="{StaticResource LaunchWindowWidth}"
        MinHeight="{StaticResource LaunchWindowHeight}"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CardBg}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Resources>
        <x:Double x:Key="LaunchWindowWidth">548</x:Double>
        <x:Double x:Key="LaunchWindowHeight">256</x:Double>
        <x:Double x:Key="LaunchOuterMargin">8</x:Double>
        <x:Double x:Key="LaunchPanelPadding">10</x:Double>
        <x:Double x:Key="LaunchLeftColumnWidth">186</x:Double>
        <x:Double x:Key="LaunchGapColumnWidth">46</x:Double>
        <x:Double x:Key="LaunchRightColumnWidth">280</x:Double>
        <x:Double x:Key="LaunchMainButtonHeight">48</x:Double>
        <x:Double x:Key="LaunchSecondaryButtonHeight">48</x:Double>
        <x:Double x:Key="LaunchButtonSpacing">8</x:Double>
        <x:Double x:Key="LaunchTitleFontSize">22</x:Double>
        <x:Double x:Key="LaunchVersionFontSize">9</x:Double>
        <x:Double x:Key="LaunchSecondaryButtonCornerRadius">9</x:Double>
    </Window.Resources>

    <Grid RowDefinitions="30,*"
          Background="{DynamicResource CardBg}">
        <Grid Grid.Row="0"
              Background="Transparent"
              PointerPressed="TitleBar_PointerPressed"
              DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0"
                        Spacing="{StaticResource LaunchButtonSpacing}"
                        IsHitTestVisible="False">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="14"
                       Height="14"/>
                <TextBlock Text="NexStrap"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="{StaticResource LaunchOuterMargin},6,{StaticResource LaunchOuterMargin},{StaticResource LaunchOuterMargin}"
                Classes="area-panel"
                Padding="{StaticResource LaunchPanelPadding}">
            <Grid ColumnDefinitions="186,46,280">
                <StackPanel Margin="10,10,0,0"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            Spacing="4">
                    <Grid ColumnDefinitions="66,*"
                          VerticalAlignment="Center">
                        <Border Width="66"
                                Height="66"
                                CornerRadius="17"
                                Background="{DynamicResource SurfaceBg}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                HorizontalAlignment="Center">
                            <Image Source="avares://NexStrap/Assets/nexstrap.png"
                                   Width="56"
                                   Height="56"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Spacing="1">
                            <TextBlock Text="NexStrap"
                                       FontSize="{StaticResource LaunchTitleFontSize}"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFF"
                                       TextAlignment="Left"/>
                            <TextBlock Text="{Binding VersionText}"
                                       FontSize="{StaticResource LaunchVersionFontSize}"
                                       Foreground="{DynamicResource FgMuted}"
                                       Opacity="0.8"
                                       TextAlignment="Left"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="2,-1,0,0"
                                Spacing="1">
                        <TextBlock Text="Roblox launcher"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgSub}"
                                   HorizontalAlignment="Left"
                                   TextAlignment="Left"/>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="10"
                                   Foreground="{DynamicResource FgMuted}"
                                   HorizontalAlignment="Left"
                                   TextAlignment="Left"/>
                    </StackPanel>

                    <StackPanel Margin="0,4,0,0"
                                Spacing="1">
                        <Button Classes="plain"
                                Command="{Binding OpenAboutCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <TextBlock Text="NexStrapについて"
                                       FontSize="10"
                                       Foreground="{DynamicResource FgMuted}"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <Button Classes="plain"
                                Command="{Binding OpenGitHubCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <TextBlock Text="GitHub"
                                       FontSize="10"
                                       Foreground="{DynamicResource FgMuted}"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <Button Classes="plain"
                                Command="{Binding OpenDiscordCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <TextBlock Text="Discord"
                                       FontSize="10"
                                       Foreground="{DynamicResource FgMuted}"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Stretch"
                            Margin="0,2,0,2"
                            Spacing="{StaticResource LaunchButtonSpacing}">
                    <Button Command="{Binding LaunchRobloxCommand}"
                            IsEnabled="{Binding IsLaunchingRoblox, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Stretch"
                            Background="#FFFFFF"
                            Foreground="#111111"
                            BorderBrush="#FFFFFF"
                            BorderThickness="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Height="{StaticResource LaunchMainButtonHeight}"
                            Padding="14,6"
                            CornerRadius="11">
                            <Grid ColumnDefinitions="*,Auto"
                                  VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center"
                                            Spacing="1">
                                    <TextBlock Text="Launch Roblox"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           LineHeight="16"
                                           Foreground="#080808"/>
                                <TextBlock Text="Recommended start"
                                           FontSize="10"
                                           LineHeight="12"
                                           Foreground="#555555"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text=">"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#1F1F1F"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                            </Grid>
                    </Button>

                    <Grid ColumnDefinitions="*,*">
                        <Button Grid.Column="0"
                                Command="{Binding OpenSettingsCommand}"
                                HorizontalAlignment="Stretch"
                                Background="#151515"
                                Foreground="#C9C9C9"
                                BorderBrush="#2A2A2A"
                                BorderThickness="1"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                FontSize="11"
                                FontWeight="Normal"
                                Height="{StaticResource LaunchSecondaryButtonHeight}"
                                Padding="12,6"
                                CornerRadius="{StaticResource LaunchSecondaryButtonCornerRadius}">
                            <Grid>
                                <TextBlock Text="Settings"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#D0D0D0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button Grid.Column="1"
                                Command="{Binding LaunchStudioCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="8,0,0,0"
                                Background="#181818"
                                Foreground="#DCDCDC"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                FontSize="11"
                                FontWeight="Normal"
                                Height="{StaticResource LaunchSecondaryButtonHeight}"
                                Padding="12,6"
                                CornerRadius="{StaticResource LaunchSecondaryButtonCornerRadius}">
                            <Grid>
                                <TextBlock Text="Studio"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#E3E3E3"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
