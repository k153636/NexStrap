<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.LaunchWindow"
        x:DataType="vm:LaunchWindowViewModel"
        Title="NexStrap"
        Icon="avares://NexStrap/Assets/nexstrap.png"
        Width="{StaticResource LaunchWindowWidth}"
        Height="{StaticResource LaunchWindowHeight}"
        MinWidth="{StaticResource LaunchWindowWidth}"
        MinHeight="{StaticResource LaunchWindowHeight}"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CardBg}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Resources>
        <x:Double x:Key="LaunchWindowWidth">576</x:Double>
        <x:Double x:Key="LaunchWindowHeight">344</x:Double>
        <Thickness x:Key="LaunchOuterMargin">8,6,8,8</Thickness>
        <Thickness x:Key="LaunchPanelPadding">10</Thickness>
        <x:Double x:Key="LaunchLeftColumnWidth">184</x:Double>
        <x:Double x:Key="LaunchGapColumnWidth">24</x:Double>
        <x:Double x:Key="LaunchRightColumnWidth">332</x:Double>
        <x:Double x:Key="LaunchMainButtonHeight">48</x:Double>
        <x:Double x:Key="LaunchSecondaryButtonHeight">48</x:Double>
        <x:Double x:Key="LaunchButtonSpacing">8</x:Double>
        <x:Double x:Key="LaunchTitleFontSize">23</x:Double>
        <x:Double x:Key="LaunchVersionFontSize">10</x:Double>
        <CornerRadius x:Key="LaunchSecondaryButtonCornerRadius">7</CornerRadius>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.launch-primary">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="0:0:0.10"
                                      Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.launch-primary:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Button.launch-secondary">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="0:0:0.08"
                                      Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.launch-secondary:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.launch-secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="BorderBrush" Value="#404040"/>
        </Style>

        <Style Selector="Button.launch-link">
            <Setter Property="Opacity" Value="0.78"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="0:0:0.10"
                                      Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.launch-link:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="30,*"
          Background="{DynamicResource CardBg}">
        <Grid Grid.Row="0"
              Background="Transparent"
              PointerPressed="TitleBar_PointerPressed"
              DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0"
                        Spacing="{StaticResource LaunchButtonSpacing}"
                        IsHitTestVisible="False">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="14"
                       Height="14"/>
                <TextBlock Text="NexStrap"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="{StaticResource LaunchOuterMargin}"
                Classes="area-panel"
                Padding="{StaticResource LaunchPanelPadding}">
            <Grid ColumnDefinitions="184,24,332">
                <StackPanel Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Spacing="12">
                    <StackPanel HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Spacing="4">
                        <Border Width="72"
                                Height="72"
                                CornerRadius="18"
                                Background="{DynamicResource SurfaceBg}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                HorizontalAlignment="Left">
                            <Image Source="avares://NexStrap/Assets/nexstrap.png"
                                   Width="60"
                                   Height="60"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        </Border>

                        <StackPanel HorizontalAlignment="Left"
                                    Spacing="0">
                            <TextBlock Text="NexStrap"
                                       FontSize="{StaticResource LaunchTitleFontSize}"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFF"
                                       TextAlignment="Left"/>
                            <TextBlock Text="{Binding VersionText}"
                                       FontSize="{StaticResource LaunchVersionFontSize}"
                                       Foreground="{DynamicResource FgMuted}"
                                       Opacity="0.75"
                                       TextAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,10,0,0"
                                Spacing="2">
                        <Button Classes="plain launch-link"
                                Command="{Binding OpenAboutCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <Grid ColumnDefinitions="14,*">
                                <PathIcon Data="{StaticResource IconInfo}"
                                          Width="11"
                                          Height="11"
                                          Foreground="{DynamicResource FgMuted}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="NexStrapについて"
                                           FontSize="10"
                                          Foreground="{DynamicResource FgMuted}"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button Classes="plain launch-link"
                                Command="{Binding OpenGitHubCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <Grid ColumnDefinitions="14,*">
                                <PathIcon Data="{StaticResource IconGlobe}"
                                          Width="11"
                                          Height="11"
                                          Foreground="{DynamicResource FgMuted}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="GitHub"
                                           FontSize="10"
                                           Foreground="{DynamicResource FgMuted}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button Classes="plain launch-link"
                                Command="{Binding OpenDiscordCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <Grid ColumnDefinitions="14,*">
                                <PathIcon Data="{StaticResource IconChat}"
                                          Width="11"
                                          Height="11"
                                          Foreground="{DynamicResource FgMuted}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="Discord"
                                           FontSize="10"
                                          Foreground="{DynamicResource FgMuted}"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="2"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Right"
                      Margin="0,2,0,2"
                      RowDefinitions="Auto,Auto,Auto">
                    <Button Command="{Binding LaunchRobloxCommand}"
                            Classes="launch-primary"
                            IsEnabled="{Binding IsLaunchingRoblox, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Stretch"
                            Background="#FFFFFF"
                            Foreground="#111111"
                            BorderBrush="#FFFFFF"
                            BorderThickness="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Height="{StaticResource LaunchMainButtonHeight}"
                            Width="{StaticResource LaunchRightColumnWidth}"
                            Padding="14,6"
                            CornerRadius="7">
                        <Grid ColumnDefinitions="18,*,Auto"
                              VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPlay}"
                                      Width="12"
                                      Height="12"
                                      Foreground="#080808"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Launch Roblox"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       LineHeight="17"
                                       Foreground="#080808"
                                       Margin="6,0,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text=">"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#1F1F1F"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Grid.Row="1"
                            Classes="launch-secondary"
                            Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,9,0,0"
                            Background="#151515"
                            Foreground="#C9C9C9"
                            BorderBrush="#262626"
                            BorderThickness="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="14"
                            FontWeight="Normal"
                            Height="{StaticResource LaunchSecondaryButtonHeight}"
                            Width="{StaticResource LaunchRightColumnWidth}"
                            Padding="14,6"
                            CornerRadius="{StaticResource LaunchSecondaryButtonCornerRadius}">
                        <Grid ColumnDefinitions="18,*,Auto"
                              VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconSettings}"
                                      Width="11"
                                      Height="11"
                                      Foreground="#D0D0D0"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Settings"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#D0D0D0"
                                       Margin="6,0,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text=">"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#8C8C8C"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Grid.Row="2"
                            Classes="launch-secondary"
                            Command="{Binding LaunchStudioCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,9,0,0"
                            Background="#181818"
                            Foreground="#DCDCDC"
                            BorderBrush="#262626"
                            BorderThickness="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="14"
                            FontWeight="Normal"
                            Height="{StaticResource LaunchSecondaryButtonHeight}"
                            Width="{StaticResource LaunchRightColumnWidth}"
                            Padding="14,6"
                            CornerRadius="{StaticResource LaunchSecondaryButtonCornerRadius}">
                        <Grid ColumnDefinitions="18,*,Auto"
                              VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconVideo}"
                                      Width="11"
                                      Height="11"
                                      Foreground="#E3E3E3"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Studio"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#E3E3E3"
                                       Margin="6,0,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text=">"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#8C8C8C"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
