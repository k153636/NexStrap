<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.LaunchWindow"
        x:DataType="vm:LaunchWindowViewModel"
        Title="NexStrap"
        Icon="avares://NexStrap/Assets/nexstrap.png"
        Width="792" Height="330"
        MinWidth="792" MinHeight="330"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="0">

    <Grid RowDefinitions="28,*">
        <Grid Grid.Row="0" Background="Transparent"
              PointerPressed="TitleBar_PointerPressed"
              DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="12,0" Spacing="7" IsHitTestVisible="False">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="16" Height="16"/>
                <TextBlock Text="NexStrap"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="16,8,16,16"
                Classes="area-panel"
                Padding="18,16,18,16">
            <Grid ColumnDefinitions="238,*">
                <StackPanel Margin="2,6,18,4"
                            VerticalAlignment="Top"
                            Spacing="10">
                    <Border Width="86" Height="86"
                            CornerRadius="22"
                            Background="{DynamicResource SurfaceBg}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Image Source="avares://NexStrap/Assets/nexstrap.png"
                               Width="86" Height="86"
                               RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    </Border>

                    <StackPanel Margin="0,10,0,0" Spacing="4">
                        <TextBlock Text="NexStrap"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"/>
                        <TextBlock Text="Roblox launcher"
                                   FontSize="13"
                                   Foreground="{DynamicResource FgSub}"/>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgMuted}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Stretch"
                            Margin="0,14,4,4"
                            Spacing="10">
                    <Button Content="Launch Roblox"
                            Command="{Binding LaunchRobloxCommand}"
                            IsEnabled="{Binding IsLaunchingRoblox, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Stretch"
                            Background="#FFFFFF"
                            Foreground="#080808"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Height="58"
                            Padding="16,14"
                            CornerRadius="12"/>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                        <Button Grid.Column="0"
                                Content="Settings"
                                Command="{Binding OpenSettingsCommand}"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource SurfaceBg}"
                                Foreground="{DynamicResource FgSub}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Height="50"
                                Padding="16,12"
                                CornerRadius="12"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Content="Studio"
                                Command="{Binding LaunchStudioCommand}"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource SurfaceBg}"
                                Foreground="{DynamicResource FgSub}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Height="50"
                                Padding="16,12"
                                CornerRadius="12"
                                Margin="8,0,0,0"/>
                    </Grid>

                    <Button Content="Launch NexStrap"
                            Command="{Binding LaunchAppCommand}"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            Foreground="{DynamicResource FgMuted}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            FontSize="13"
                            Height="50"
                            Padding="16,12"
                            CornerRadius="12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
