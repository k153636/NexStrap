<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.LaunchWindow"
        x:DataType="vm:LaunchWindowViewModel"
        Title="NexStrap"
        Icon="avares://NexStrap/Assets/nexstrap.png"
        Width="{StaticResource LaunchWindowWidth}"
        Height="{StaticResource LaunchWindowHeight}"
        MinWidth="{StaticResource LaunchWindowWidth}"
        MinHeight="{StaticResource LaunchWindowHeight}"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CardBg}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Resources>
        <x:Double x:Key="LaunchWindowWidth">565</x:Double>
        <x:Double x:Key="LaunchWindowHeight">234</x:Double>
        <Thickness x:Key="LaunchOuterMargin">4,2,4,4</Thickness>
        <Thickness x:Key="LaunchPanelPadding">0</Thickness>
        <x:Double x:Key="LaunchLeftColumnWidth">280</x:Double>
        <x:Double x:Key="LaunchGapColumnWidth">16</x:Double>
        <x:Double x:Key="LaunchRightColumnWidth">268</x:Double>
        <x:Double x:Key="LaunchMainButtonHeight">55</x:Double>
        <x:Double x:Key="LaunchSecondaryButtonHeight">55</x:Double>
        <x:Double x:Key="LaunchButtonSpacing">8</x:Double>
        <x:Double x:Key="LaunchTitleFontSize">25</x:Double>
        <x:Double x:Key="LaunchVersionFontSize">12</x:Double>
        <CornerRadius x:Key="LaunchSecondaryButtonCornerRadius">8</CornerRadius>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.launch-primary">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="0:0:0.10"
                                      Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.launch-primary:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Button.launch-secondary">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="0:0:0.08"
                                      Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.launch-secondary:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.launch-secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="BorderBrush" Value="#404040"/>
        </Style>

        <Style Selector="Button.launch-link">
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="0:0:0.10"
                                      Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.launch-link:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="26,*"
          Background="{DynamicResource CardBg}">
        <Grid Grid.Row="0"
              Background="Transparent"
              PointerPressed="TitleBar_PointerPressed">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0"
                        Spacing="{StaticResource LaunchButtonSpacing}"
                        IsHitTestVisible="False">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="14"
                       Height="14"/>
                <TextBlock Text="NexStrap"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Button Content="×"
                    Click="CloseButton_Click"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource SubtextBrush}"
                    FontSize="18"
                    FontWeight="Normal"
                    Padding="0"
                    Opacity="0.75"/>
        </Grid>

        <Border Grid.Row="1"
                Margin="{StaticResource LaunchOuterMargin}"
                Classes="area-panel"
                Padding="{StaticResource LaunchPanelPadding}">
            <Grid ColumnDefinitions="280,16,268">
                <StackPanel Grid.Column="0"
                            Width="{StaticResource LaunchLeftColumnWidth}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="0">
                    <Grid HorizontalAlignment="Center"
                          Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="72"
                                Height="72"
                                CornerRadius="18"
                                Background="{DynamicResource SurfaceBg}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                HorizontalAlignment="Left">
                            <Image Source="avares://NexStrap/Assets/nexstrap.png"
                                   Width="60"
                                   Height="60"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Spacing="0">
                            <TextBlock Text="NexStrap"
                                       FontSize="{StaticResource LaunchTitleFontSize}"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFF"
                                       TextAlignment="Left"/>
                            <TextBlock Text="{Binding VersionText}"
                                       FontSize="{StaticResource LaunchVersionFontSize}"
                                       Foreground="{DynamicResource FgMuted}"
                                       Opacity="0.75"
                                       TextAlignment="Left"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,0"
                                Spacing="8">
                        <Button Classes="plain launch-link"
                                Command="{Binding OpenAboutCommand}"
                                HorizontalAlignment="Center"
                                Padding="0"
                                Background="Transparent">
                            <Grid ColumnDefinitions="14,*">
                                <PathIcon Data="{StaticResource IconInfo}"
                                          Width="12"
                                          Height="12"
                                          Foreground="{DynamicResource FgMuted}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="NexStrapについて"
                                           FontSize="11"
                                           Foreground="{DynamicResource FgMuted}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button Classes="plain launch-link"
                                Command="{Binding OpenGitHubCommand}"
                                HorizontalAlignment="Center"
                                Padding="0"
                                Background="Transparent">
                            <Grid ColumnDefinitions="14,*">
                                <PathIcon Data="{StaticResource IconGlobe}"
                                          Width="12"
                                          Height="12"
                                          Foreground="{DynamicResource FgMuted}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="GitHub"
                                           FontSize="11"
                                           Foreground="{DynamicResource FgMuted}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button Classes="plain launch-link"
                                Command="{Binding OpenDiscordCommand}"
                                HorizontalAlignment="Center"
                                Padding="0"
                                Background="Transparent">
                            <Grid ColumnDefinitions="14,*">
                                <PathIcon Data="{StaticResource IconChat}"
                                          Width="12"
                                          Height="12"
                                          Foreground="{DynamicResource FgMuted}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="Discord"
                                           FontSize="11"
                                           Foreground="{DynamicResource FgMuted}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Width="{StaticResource LaunchRightColumnWidth}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,18,0"
                            Spacing="8">
                    <Button Command="{Binding LaunchRobloxCommand}"
                            Classes="launch-primary"
                            IsEnabled="{Binding IsLaunchingRoblox, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Stretch"
                            Background="#181818"
                            Foreground="#E3E3E3"
                            BorderBrush="#262626"
                            BorderThickness="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Height="{StaticResource LaunchMainButtonHeight}"
                            Width="{StaticResource LaunchRightColumnWidth}"
                            Padding="16,0"
                            CornerRadius="8">
                        <Grid ColumnDefinitions="18,*,12"
                              VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPlay}"
                                      Width="12"
                                      Height="12"
                                      Foreground="#E3E3E3"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Launch Roblox"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       LineHeight="17"
                                       Foreground="#E3E3E3"
                                       Margin="6,0,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text=">"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#E3E3E3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Classes="launch-secondary"
                            Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#151515"
                            Foreground="#C9C9C9"
                            BorderBrush="#262626"
                            BorderThickness="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="13"
                            FontWeight="Normal"
                            Height="{StaticResource LaunchSecondaryButtonHeight}"
                            Width="{StaticResource LaunchRightColumnWidth}"
                            Padding="16,0"
                            CornerRadius="{StaticResource LaunchSecondaryButtonCornerRadius}">
                        <Grid ColumnDefinitions="18,*,12"
                              VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconSettings}"
                                      Width="11"
                                      Height="11"
                                      Foreground="#D0D0D0"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Settings"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#D0D0D0"
                                       Margin="6,0,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text=">"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#D0D0D0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Classes="launch-secondary"
                            Command="{Binding LaunchStudioCommand}"
                            IsEnabled="{Binding IsLaunchingStudio, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Stretch"
                            Background="#181818"
                            Foreground="#DCDCDC"
                            BorderBrush="#262626"
                            BorderThickness="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="13"
                            FontWeight="Normal"
                            Height="{StaticResource LaunchSecondaryButtonHeight}"
                            Width="{StaticResource LaunchRightColumnWidth}"
                            Padding="16,0"
                            CornerRadius="{StaticResource LaunchSecondaryButtonCornerRadius}">
                        <Grid ColumnDefinitions="18,*,12"
                              VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconVideo}"
                                      Width="11"
                                      Height="11"
                                      Foreground="#E3E3E3"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Studio"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#E3E3E3"
                                       Margin="6,0,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text=">"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#E3E3E3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
