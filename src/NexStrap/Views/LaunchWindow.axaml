<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.LaunchWindow"
        x:DataType="vm:LaunchWindowViewModel"
        Title="NexStrap"
        Icon="avares://NexStrap/Assets/nexstrap.png"
        Width="720"
        Height="334"
        MinWidth="720"
        MinHeight="334"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CardBg}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Grid RowDefinitions="30,*"
          Background="{DynamicResource CardBg}">
        <Grid Grid.Row="0"
              Background="Transparent"
              PointerPressed="TitleBar_PointerPressed"
              DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0"
                        Spacing="5"
                        IsHitTestVisible="False">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="14"
                       Height="14"/>
                <TextBlock Text="NexStrap"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="8,6,8,8"
                Classes="area-panel"
                Padding="10">
            <Grid ColumnDefinitions="220,150,300">
                <StackPanel Margin="2,4,8,0"
                            VerticalAlignment="Top"
                            Spacing="6">
                    <Border Width="66"
                            Height="66"
                            CornerRadius="17"
                            Background="{DynamicResource SurfaceBg}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Image Source="avares://NexStrap/Assets/nexstrap.png"
                               Width="66"
                               Height="66"
                               RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    </Border>

                    <StackPanel Margin="0,2,0,0"
                                Spacing="1">
                        <TextBlock Text="NexStrap"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"/>
                        <TextBlock Text="Roblox launcher"
                                   FontSize="12"
                                   Foreground="{DynamicResource FgSub}"/>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgMuted}"/>
                    </StackPanel>

                    <StackPanel Margin="0,6,0,0"
                                Spacing="2">
                        <Button Classes="plain"
                                Command="{Binding OpenAboutCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <TextBlock Text="NexStrapについて"
                                       FontSize="11"
                                       Foreground="{DynamicResource FgSub}"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <Button Classes="plain"
                                Command="{Binding OpenGitHubCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <TextBlock Text="GitHub"
                                       FontSize="11"
                                       Foreground="{DynamicResource FgSub}"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <Button Classes="plain"
                                Command="{Binding OpenDiscordCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <TextBlock Text="Discord"
                                       FontSize="11"
                                       Foreground="{DynamicResource FgSub}"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Stretch"
                            Margin="0,2,0,2"
                            Spacing="8">
                    <Button Command="{Binding LaunchRobloxCommand}"
                            IsEnabled="{Binding IsLaunchingRoblox, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Stretch"
                            Background="#FFFFFF"
                            Foreground="#080808"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Height="46"
                            Padding="12,10"
                            CornerRadius="10">
                        <TextBlock Text="Launch Roblox"
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#080808"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Command="{Binding LaunchStudioCommand}"
                            HorizontalAlignment="Stretch"
                            Background="{DynamicResource SurfaceBg}"
                            Foreground="{DynamicResource FgSub}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Height="38"
                            Padding="12,7"
                            CornerRadius="10">
                        <TextBlock Text="Launch Roblox Studio"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgSub}"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Stretch"
                            Background="{DynamicResource SurfaceBg}"
                            Foreground="{DynamicResource FgSub}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Height="38"
                            Padding="12,7"
                            CornerRadius="10">
                        <TextBlock Text="Settings"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgSub}"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Command="{Binding LaunchAppCommand}"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            Foreground="{DynamicResource FgMuted}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            FontSize="12"
                            Height="38"
                            Padding="12,7"
                            CornerRadius="10">
                        <TextBlock Text="Launch NexStrap"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgMuted}"
                                   VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
