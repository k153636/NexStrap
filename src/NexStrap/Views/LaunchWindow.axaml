<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.LaunchWindow"
        x:DataType="vm:LaunchWindowViewModel"
        Title="NexStrap"
        Icon="avares://NexStrap/Assets/nexstrap.png"
        Width="720"
        Height="334"
        MinWidth="720"
        MinHeight="334"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CardBg}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Grid RowDefinitions="30,*"
          Background="{DynamicResource CardBg}">
        <Grid Grid.Row="0"
              Background="Transparent"
              PointerPressed="TitleBar_PointerPressed"
              DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0"
                        Spacing="5"
                        IsHitTestVisible="False">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="14"
                       Height="14"/>
                <TextBlock Text="NexStrap"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="8,6,8,8"
                Classes="area-panel"
                Padding="10">
            <Grid ColumnDefinitions="244,72,300">
                <StackPanel Margin="24,22,0,0"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            Spacing="7">
                    <Border Width="66"
                            Height="66"
                            CornerRadius="17"
                            Background="{DynamicResource SurfaceBg}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            HorizontalAlignment="Center">
                        <Image Source="avares://NexStrap/Assets/nexstrap.png"
                               Width="66"
                               Height="66"
                               RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    </Border>

                    <StackPanel Margin="0,4,0,0"
                                Spacing="2"
                                HorizontalAlignment="Center">
                        <TextBlock Text="NexStrap"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Roblox launcher"
                                   FontSize="12"
                                   Foreground="{DynamicResource FgSub}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgMuted}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Margin="0,8,0,0"
                                Spacing="1">
                        <Button Classes="plain"
                                Command="{Binding OpenAboutCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <TextBlock Text="NexStrapについて"
                                       FontSize="10"
                                       Foreground="{DynamicResource FgMuted}"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <Button Classes="plain"
                                Command="{Binding OpenGitHubCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <TextBlock Text="GitHub"
                                       FontSize="10"
                                       Foreground="{DynamicResource FgMuted}"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <Button Classes="plain"
                                Command="{Binding OpenDiscordCommand}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent">
                            <TextBlock Text="Discord"
                                       FontSize="10"
                                       Foreground="{DynamicResource FgMuted}"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Stretch"
                            Margin="0,2,0,2"
                            Spacing="8">
                    <Button Command="{Binding LaunchRobloxCommand}"
                            IsEnabled="{Binding IsLaunchingRoblox, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Stretch"
                            Background="#FFFFFF"
                            Foreground="#111111"
                            BorderBrush="#FFFFFF"
                            BorderThickness="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Height="56"
                            Padding="16,8"
                            CornerRadius="12">
                        <Grid ColumnDefinitions="*,Auto"
                              VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center"
                                        Spacing="2">
                                <TextBlock Text="Launch Roblox"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           LineHeight="18"
                                           Foreground="#080808"/>
                                <TextBlock Text="Recommended start"
                                           FontSize="11"
                                           LineHeight="14"
                                           Foreground="#555555"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text=">"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1F1F1F"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Command="{Binding LaunchStudioCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#181818"
                            Foreground="#DCDCDC"
                            BorderBrush="#303030"
                            BorderThickness="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="12"
                            FontWeight="Normal"
                            Height="40"
                            Padding="14,8"
                            CornerRadius="10">
                        <Grid>
                            <TextBlock Text="Launch Roblox Studio"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#E3E3E3"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#151515"
                            Foreground="#C9C9C9"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="12"
                            FontWeight="Normal"
                            Height="40"
                            Padding="14,8"
                            CornerRadius="10">
                        <Grid>
                            <TextBlock Text="Settings"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#D0D0D0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Command="{Binding LaunchAppCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#111111"
                            Foreground="#8E8E8E"
                            BorderBrush="#222222"
                            BorderThickness="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            FontSize="12"
                            Height="40"
                            Padding="14,8"
                            Opacity="0.72"
                            CornerRadius="10">
                        <Grid>
                            <TextBlock Text="Launch NexStrap"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#A6A6A6"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
