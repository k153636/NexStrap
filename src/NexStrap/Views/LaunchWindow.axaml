<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.LaunchWindow"
        x:DataType="vm:LaunchWindowViewModel"
        Title="NexStrap"
        Icon="avares://NexStrap/Assets/nexstrap.png"
        Width="620" Height="300"
        MinWidth="620" MinHeight="300"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="0">

    <Grid RowDefinitions="28,*">
        <Grid Grid.Row="0" Background="Transparent"
              PointerPressed="TitleBar_PointerPressed"
              DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="12,0" Spacing="7" IsHitTestVisible="False">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="16" Height="16"/>
                <TextBlock Text="NexStrap"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="18,6,18,18"
                Classes="area-panel"
                Padding="22">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                <Border Width="72" Height="72"
                        CornerRadius="18"
                        Background="{DynamicResource SurfaceBg}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Image Source="avares://NexStrap/Assets/nexstrap.png"
                           Width="72" Height="72"
                           RenderOptions.BitmapInterpolationMode="HighQuality"/>
                </Border>

                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center" Margin="18,0,0,0">
                    <TextBlock Text="NexStrap"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="Start the launcher or Roblox directly"
                               FontSize="12"
                               Foreground="{DynamicResource FgSub}"/>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="{DynamicResource FgMuted}"/>
                </StackPanel>

                <StackPanel Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8"
                            Margin="0,18,0,0">
                    <Button Content="Launch NexStrap"
                            Command="{Binding LaunchAppCommand}"
                            Background="#FFFFFF"
                            Foreground="#080808"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Padding="16,11"
                            CornerRadius="10"/>
                    <Button Content="Launch Roblox"
                            Command="{Binding LaunchRobloxCommand}"
                            IsEnabled="{Binding IsLaunchingRoblox, Converter={x:Static BoolConverters.Not}}"
                            Background="{DynamicResource SurfaceBg}"
                            Foreground="{DynamicResource FgSub}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Padding="16,11"
                            CornerRadius="10"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
