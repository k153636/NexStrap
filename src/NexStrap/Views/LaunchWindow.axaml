<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.LaunchWindow"
        x:DataType="vm:LaunchWindowViewModel"
        Title="NexStrap"
        Icon="avares://NexStrap/Assets/nexstrap.png"
        Width="724" Height="304"
        MinWidth="724" MinHeight="304"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="0">

    <Grid RowDefinitions="28,*">
        <Grid Grid.Row="0" Background="Transparent"
              PointerPressed="TitleBar_PointerPressed"
              DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="12,0" Spacing="7" IsHitTestVisible="False">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="16" Height="16"/>
                <TextBlock Text="NexStrap"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="14,8,14,14"
                Classes="area-panel"
                Padding="16,14,16,14">
            <Grid ColumnDefinitions="218,*">
                <StackPanel Margin="4,8,14,4"
                            VerticalAlignment="Top"
                            Spacing="8">
                    <Border Width="74" Height="74"
                            CornerRadius="18"
                            Background="{DynamicResource SurfaceBg}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Image Source="avares://NexStrap/Assets/nexstrap.png"
                               Width="74" Height="74"
                               RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    </Border>

                    <StackPanel Margin="0,8,0,0" Spacing="3">
                        <TextBlock Text="NexStrap"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"/>
                        <TextBlock Text="Roblox launcher"
                                   FontSize="12"
                                   Foreground="{DynamicResource FgSub}"/>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgMuted}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Stretch"
                            Margin="0,10,4,4"
                            Spacing="7">
                    <Button Content="Launch Roblox"
                            Command="{Binding LaunchRobloxCommand}"
                            IsEnabled="{Binding IsLaunchingRoblox, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Stretch"
                            Background="#FFFFFF"
                            Foreground="#080808"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Height="52"
                            Padding="16,13"
                            CornerRadius="11"/>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                        <Button Grid.Column="0"
                                Content="Settings"
                                Command="{Binding OpenSettingsCommand}"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource SurfaceBg}"
                                Foreground="{DynamicResource FgSub}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Height="46"
                                Padding="16,11"
                                CornerRadius="11"
                                Margin="0,0,5,0"/>
                        <Button Grid.Column="1"
                                Content="Studio"
                                Command="{Binding LaunchStudioCommand}"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource SurfaceBg}"
                                Foreground="{DynamicResource FgSub}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Height="46"
                                Padding="16,11"
                                CornerRadius="11"
                                Margin="5,0,0,0"/>
                    </Grid>

                    <Button Content="Launch NexStrap"
                            Command="{Binding LaunchAppCommand}"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            Foreground="{DynamicResource FgMuted}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            FontSize="12"
                            Height="46"
                            Padding="16,11"
                            CornerRadius="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
