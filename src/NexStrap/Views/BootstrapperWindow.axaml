<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.BootstrapperWindow"
        x:DataType="vm:BootstrapperViewModel"
        Title="NexStrap"
        Width="440" Height="240"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#080808"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        Icon="avares://NexStrap/Assets/nexstrap.png">

    <Grid RowDefinitions="*,Auto" Margin="0,32,0,0">

        <!-- Center content -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="18" Margin="40,0">

            <!-- Logo + title -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="40" Height="40" VerticalAlignment="Center"/>
                <TextBlock Text="NexStrap" FontSize="22" FontWeight="Bold"
                           Foreground="#FFFFFF" VerticalAlignment="Center"
                           FontFamily="Segoe UI, sans-serif"/>
            </StackPanel>

            <!-- Status text -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="13" Foreground="#888888"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

            <!-- Progress bar -->
            <StackPanel Spacing="6">
                <ProgressBar Value="{Binding ProgressValue}"
                             Minimum="0" Maximum="100"
                             IsIndeterminate="{Binding IsIndeterminate}"
                             Height="4"
                             Width="360"
                             CornerRadius="2"
                             Foreground="#FFFFFF"
                             Background="#222222"/>

                <TextBlock HorizontalAlignment="Right" Width="360"
                           FontSize="11" Foreground="#444444"
                           IsVisible="{Binding !IsIndeterminate}"
                           Text="{Binding ProgressValue, StringFormat='{}{0:F0}%'}"/>
            </StackPanel>

        </StackPanel>

        <!-- Cancel button -->
        <Button Grid.Row="1"
                Content="Cancel"
                Command="{Binding CancelCommand}"
                IsVisible="{Binding IsCancelVisible}"
                HorizontalAlignment="Center"
                Margin="0,0,0,20"
                Background="Transparent"
                Foreground="#444444"
                FontSize="12"
                Padding="20,6"
                CornerRadius="8"
                BorderBrush="#222222"
                BorderThickness="1"/>
    </Grid>

</Window>
