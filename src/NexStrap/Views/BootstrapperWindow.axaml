<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.BootstrapperWindow"
        x:DataType="vm:BootstrapperViewModel"
        Title="NexStrap"
        Width="440" Height="240"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Topmost="True"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        Icon="avares://NexStrap/Assets/nexstrap.png">

    <Grid>

        <!-- Base dark bg -->
        <Rectangle Fill="#080808"/>

        <!-- Loading screen image — no blur, opacity 0.85 -->
        <Image Source="{Binding BackgroundImagePath, Converter={StaticResource StringToImageConverter}}"
               Stretch="UniformToFill"
               Opacity="0.85"
               IsVisible="{Binding HasBackgroundImage}"/>

        <!-- Dark scrim over image -->
        <Rectangle Fill="#AA080808" IsVisible="{Binding HasBackgroundImage}"/>

        <!-- Fake title bar -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top"
                    Margin="12,10" Spacing="7">
            <Image Source="avares://NexStrap/Assets/nexstrap.png"
                   Width="14" Height="14"/>
            <TextBlock Text="NexStrap" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Center content -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="16" Margin="40,0,40,24">

            <!-- Logo + title -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="36" Height="36" VerticalAlignment="Center"/>
                <TextBlock Text="NexStrap" FontSize="20" FontWeight="Bold"
                           Foreground="#FFFFFF" VerticalAlignment="Center"
                           FontFamily="Segoe UI, sans-serif"/>
            </StackPanel>

            <!-- Status text -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12" Foreground="{DynamicResource SubtextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

            <!-- Progress bar + detail row -->
            <StackPanel Spacing="5">
                <ProgressBar Value="{Binding ProgressValue}"
                             Minimum="0" Maximum="100"
                             IsIndeterminate="{Binding IsIndeterminate}"
                             Height="4" Width="320"
                             CornerRadius="2"
                             Foreground="#FFFFFF"
                             Background="#222222"/>

                <Grid Width="320" IsVisible="{Binding !IsIndeterminate}">
                    <TextBlock HorizontalAlignment="Left"
                               FontSize="11" Foreground="{DynamicResource MutedBrush}"
                               IsVisible="{Binding HasDetail}"
                               Text="{Binding DetailText}"/>
                    <TextBlock HorizontalAlignment="Right"
                               FontSize="11" Foreground="{DynamicResource MutedBrush}"
                               Text="{Binding ProgressValue, StringFormat='{}{0:F0}%'}"/>
                </Grid>
            </StackPanel>

        </StackPanel>

        <!-- Cancel button -->
        <Button Content="Cancel"
                Command="{Binding CancelCommand}"
                IsVisible="{Binding IsCancelVisible}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,16"
                Background="Transparent"
                Foreground="{DynamicResource MutedBrush}"
                FontSize="11"
                Padding="18,5"
                CornerRadius="8"
                BorderBrush="#222222"
                BorderThickness="1"/>

    </Grid>

</Window>
