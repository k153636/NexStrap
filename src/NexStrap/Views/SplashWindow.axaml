<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NexStrap.Views.SplashWindow"
        Width="380" Height="260"
        Background="#000000"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        CanResize="False"
        ShowInTaskbar="False">

    <Grid>

        <!-- Deep radial vignette: subtle centre lift, pitch-black edge -->
        <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.46" GradientOrigin="0.5,0.46"
                                     RadiusX="0.55" RadiusY="0.55">
                    <GradientStop Color="#131313" Offset="0"/>
                    <GradientStop Color="#000000" Offset="0.8"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Splash content: scales + fades in as a unit -->
        <StackPanel x:Name="SplashContent"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="14"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">

            <!-- Logo + glow halo layered in a fixed cell -->
            <Grid Width="100" Height="100" HorizontalAlignment="Center">

                <!-- Glow ellipse — behind logo, pulsed once after appear -->
                <Ellipse x:Name="GlowEllipse"
                         Width="96" Height="96"
                         Opacity="0"
                         IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#3CFFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Logo — no DropShadowEffect (causes frame drops) -->
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="58" Height="58"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapInterpolationMode="HighQuality"/>
            </Grid>

            <!-- Wordmark -->
            <StackPanel HorizontalAlignment="Center" Spacing="5">
                <TextBlock Text="NexStrap"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           LetterSpacing="1.5"/>
                <TextBlock Text="Roblox Utility"
                           FontSize="10"
                           Foreground="#363636"
                           HorizontalAlignment="Center"/>
            </StackPanel>

        </StackPanel>

        <!-- Test-mode controls (shown only when IsTestMode = true) -->
        <StackPanel x:Name="TestControls"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Orientation="Horizontal" Spacing="8" Margin="0,0,0,18"
                    IsVisible="False">
            <Button x:Name="ReplayButton" Content="⟳  Replay"
                    Background="#1A1A1A" Foreground="#666666"
                    BorderBrush="#2A2A2A" BorderThickness="1"
                    FontSize="11" Padding="14,6" CornerRadius="6"
                    Click="ReplayButton_Click"/>
            <Button x:Name="CloseTestButton" Content="✕  Close"
                    Background="#1A1A1A" Foreground="#666666"
                    BorderBrush="#2A2A2A" BorderThickness="1"
                    FontSize="11" Padding="14,6" CornerRadius="6"
                    Click="CloseTestButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
