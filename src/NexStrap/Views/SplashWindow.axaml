<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NexStrap.Views.SplashWindow"
        Width="380" Height="260"
        Background="#000000"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        CanResize="False"
        ShowInTaskbar="False">

    <Grid>

        <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.46" GradientOrigin="0.5,0.46"
                                     RadiusX="0.55" RadiusY="0.55">
                    <GradientStop Color="#131313" Offset="0"/>
                    <GradientStop Color="#000000" Offset="0.8"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <StackPanel x:Name="SplashContent"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="16" Opacity="0"
                    RenderTransformOrigin="0.5,0.5">

            <Border x:Name="LogoWrapper"
                    Width="58" Height="58"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    RenderTransformOrigin="50%,50%">
                <Image x:Name="LogoImage"
                       Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="58" Height="58"
                       RenderOptions.BitmapInterpolationMode="HighQuality"/>
            </Border>

            <TextBlock Text="NexStrap"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center"
                       LetterSpacing="1.5"/>

        </StackPanel>

        <StackPanel x:Name="TestControls"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Orientation="Horizontal" Spacing="8" Margin="0,0,0,18"
                    IsVisible="False">
            <Button x:Name="ReplayButton" Content="⟳  Replay"
                    Background="#1A1A1A" Foreground="#666666"
                    BorderBrush="#2A2A2A" BorderThickness="1"
                    FontSize="11" Padding="14,6" CornerRadius="6"
                    Click="ReplayButton_Click"/>
            <Button x:Name="CloseTestButton" Content="✕  Close"
                    Background="#1A1A1A" Foreground="#666666"
                    BorderBrush="#2A2A2A" BorderThickness="1"
                    FontSize="11" Padding="14,6" CornerRadius="6"
                    Click="CloseTestButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
