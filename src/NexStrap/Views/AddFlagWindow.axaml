<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.AddFlagWindow"
        x:DataType="vm:FastFlagsViewModel"
        Title="Add Flag — Fast Flags"
        Width="440" Height="210"
        CanResize="False"
        Background="#080808"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="30,*">

        <Grid Grid.Row="0" IsHitTestVisible="False">
            <TextBlock Text="Add Flag" FontSize="12" FontWeight="SemiBold"
                       Foreground="#666666" VerticalAlignment="Center" Margin="14,0"/>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto" Margin="20,4,20,20">

            <TextBox Grid.Row="0" Margin="0,0,0,10"
                     Text="{Binding NewFlagName}"
                     Watermark="Flag name  (e.g. FFlagXxx)"
                     Background="#0D0D0D" Foreground="#FFFFFF"
                     BorderBrush="#2A2A2A" CornerRadius="8"
                     Padding="14,10" FontSize="12"
                     FontFamily="Consolas,Courier New,monospace"/>

            <TextBox Grid.Row="1" Margin="0,0,0,10"
                     Text="{Binding NewFlagValue}"
                     Watermark="Value"
                     Background="#0D0D0D" Foreground="#FFFFFF"
                     BorderBrush="#2A2A2A" CornerRadius="8"
                     Padding="14,10" FontSize="12"
                     FontFamily="Consolas,Courier New,monospace"/>

            <Grid Grid.Row="2" ColumnDefinitions="*,8,Auto">
                <Button Grid.Column="0"
                        Content="Add Flag"
                        Command="{Binding AddFlagCommand}"
                        Background="#FFFFFF" Foreground="#080808"
                        FontSize="13" FontWeight="SemiBold"
                        Padding="0,10" CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="Cancel"
                        Background="#1A1A1A" Foreground="#666666"
                        FontSize="13" Padding="20,10" CornerRadius="8"
                        Click="Cancel_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
