<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:vm="using:NexStrap.ViewModels"
        xmlns:pages="using:NexStrap.Views.Pages"
        x:Class="NexStrap.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="NexStrap"
        Icon="avares://NexStrap/Assets/nexstrap.png"
        Width="900" Height="620"
        MinWidth="760" MinHeight="520"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Grid x:Name="RootGrid" RowDefinitions="30,*,52">
        <Rectangle Grid.RowSpan="2" Fill="#000000"/>

        <Border Grid.RowSpan="2"
                Background="#50000000"
                IsHitTestVisible="False"
                IsVisible="{Binding ThemeVM.GlassThemeEnabled}"/>

        <Image Grid.RowSpan="2"
               Source="{Binding ThemeVM.BackgroundImagePath,
                   Converter={StaticResource StringToImageConverter}}"
               Stretch="UniformToFill"
               Opacity="{Binding ThemeVM.BackgroundImageOpacity}"
               IsVisible="{Binding ThemeVM.BackgroundImagePath,
                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <Image.Effect>
                <BlurEffect Radius="{Binding ThemeVM.BackgroundBlurRadius}"/>
            </Image.Effect>
        </Image>

        <!-- Vignette top -->
        <Rectangle Grid.RowSpan="2" IsHitTestVisible="False"
                   Fill="{Binding ThemeVM.VignetteTopBrush}"
                   Opacity="{Binding ThemeVM.BackgroundVignetteIntensity}"
                   IsVisible="{Binding ThemeVM.BackgroundImagePath,
                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <!-- Vignette bottom -->
        <Rectangle Grid.RowSpan="2" IsHitTestVisible="False"
                   Fill="{Binding ThemeVM.VignetteBottomBrush}"
                   Opacity="{Binding ThemeVM.BackgroundVignetteIntensity}"
                   IsVisible="{Binding ThemeVM.BackgroundImagePath,
                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <Grid Grid.Row="0" Background="Transparent"
              PointerPressed="TitleBar_PointerPressed"
              DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="12,0" Spacing="7" IsHitTestVisible="False">
                <Image Source="avares://NexStrap/Assets/nexstrap.png"
                       Width="16" Height="16" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                <TextBlock Text="NexStrap" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <ui:NavigationView Grid.Row="1"
                           x:Name="NavView"
                           IsPaneOpen="True"
                           PaneDisplayMode="Left"
                           OpenPaneLength="155"
                           IsBackButtonVisible="False"
                           IsSettingsVisible="False"
                           IsPaneToggleButtonVisible="False"
                           Background="Transparent"
                           SelectionChanged="NavView_SelectionChanged">

            <ui:NavigationView.MenuItems>
                <!-- 通常ナビ（Settings 以外のページ） -->
                <ui:NavigationViewItem Content="Home" Tag="Home"
                    IsVisible="{Binding !IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Home"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Fast Flags" Tag="FastFlags"
                    IsVisible="{Binding !IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Filter"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Mods" Tag="Mods"
                    IsVisible="{Binding !IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Add"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Stretch Res" Tag="Stretch"
                    IsVisible="{Binding !IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Crop"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Shortcuts" Tag="Shortcuts"
                    IsVisible="{Binding !IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Keyboard"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Stats" Tag="Stats"
                    IsVisible="{Binding !IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="List"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <!-- Settings サブナビ（Settings ページ時のみ表示） -->
                <ui:NavigationViewItem Content="Back" Tag="Home"
                    IsVisible="{Binding IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:PathIconSource Data="{StaticResource IconBack}"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="General" Tag="Settings_General"
                    IsVisible="{Binding IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Settings"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Performance" Tag="Settings_Performance"
                    IsVisible="{Binding IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Clock"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Roblox" Tag="Settings_Roblox"
                    IsVisible="{Binding IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Globe"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Data" Tag="Settings_Data"
                    IsVisible="{Binding IsOnSettingsPage}">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Save"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Account" Tag="Account">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Contact"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Theme" Tag="Theme">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="ColorBackground"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Discord RPC" Tag="Discord">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Comment"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Settings" Tag="Settings">
                    <ui:NavigationViewItem.IconSource>
                        <ui:SymbolIconSource Symbol="Settings"/>
                    </ui:NavigationViewItem.IconSource>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>

            <Border Background="{Binding ThemeVM.GlassThemeEnabled,
                Converter={StaticResource BoolToColorConverter},
                ConverterParameter='#00000000,#000000'}">
                <TransitioningContentControl Content="{Binding CurrentPage}">
                    <TransitioningContentControl.PageTransition>
                        <CrossFade Duration="0:0:0.06"/>
                    </TransitioningContentControl.PageTransition>
                    <TransitioningContentControl.DataTemplates>
                        <DataTemplate DataType="vm:HomeViewModel">
                            <pages:HomePage/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:FastFlagsViewModel">
                            <pages:FastFlagsPage/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:ModsViewModel">
                            <pages:ModsPage/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsViewModel">
                            <pages:SettingsPage/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:DiscordViewModel">
                            <pages:DiscordPage/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:ThemeViewModel">
                            <pages:ThemePage/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:StatsViewModel">
                            <pages:StatsPage/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:DevViewModel">
                            <pages:DevPage/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:AccountViewModel">
                            <pages:AccountPage/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:StretchResolutionViewModel">
                            <pages:StretchResolutionPage/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:ShortcutsViewModel">
                            <pages:ShortcutsPage/>
                        </DataTemplate>
                    </TransitioningContentControl.DataTemplates>
                </TransitioningContentControl>
            </Border>
        </ui:NavigationView>

        <!-- Global Bottom Bar -->
        <Border Grid.Row="2" Background="#050505" BorderBrush="#1C1C1C" BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid ColumnDefinitions="*,Auto">

                <!-- 左: ステータス表示（Ready 以外のみ） -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center"
                            IsVisible="{Binding HomeVM.IsRobloxRunning}">
                    <Ellipse Width="6" Height="6" Fill="#4ADE80" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding HomeVM.StatusText}"
                               FontSize="11" Foreground="#888888"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 右: 4ボタン -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">

                    <!-- Studio -->
                    <Button Content="Studio"
                            Command="{Binding HomeVM.LaunchStudioCommand}"
                            IsEnabled="{Binding HomeVM.IsStudioLaunching,
                                Converter={x:Static BoolConverters.Not}}"
                            Background="#FFFFFF" Foreground="#080808"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="8"/>

                    <!-- Save and Launch -->
                    <Button Content="Save and Launch"
                            Command="{Binding HomeVM.LaunchRobloxCommand}"
                            IsEnabled="{Binding HomeVM.IsLaunching,
                                Converter={x:Static BoolConverters.Not}}"
                            Background="#FFFFFF" Foreground="#080808"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="8"/>

                    <!-- Restart (NexStrap 再起動) -->
                    <Button Content="Restart"
                            Command="{Binding RestartAppCommand}"
                            Background="#FFFFFF" Foreground="#080808"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="8"/>

                    <!-- Save (FastFlags 適用) -->
                    <Button Content="Save"
                            Command="{Binding HomeVM.HotReloadFlagsCommand}"
                            Background="#FFFFFF" Foreground="#080808"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="8"/>

                    <!-- Close -->
                    <Button Content="Close"
                            Command="{Binding ShutdownCommand}"
                            Background="#181818" Foreground="#888888"
                            FontSize="12" Padding="14,8" CornerRadius="8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Splash overlay -->
        <Grid x:Name="SplashOverlay" Grid.RowSpan="3" IsHitTestVisible="True" Opacity="1">
            <Rectangle Fill="#000000" IsHitTestVisible="False"/>
            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.08,0.86"
                                         GradientOrigin="0.08,0.86"
                                         RadiusX="105%"
                                         RadiusY="105%">
                        <GradientStop Color="#1CFFFFFF" Offset="0"/>
                        <GradientStop Color="#08080808" Offset="0.38"/>
                        <GradientStop Color="#000000" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Border Height="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Margin="32,0,32,23"
                    Background="#12FFFFFF"
                    IsHitTestVisible="False"/>
            <Grid x:Name="SplashContent"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  Margin="34,0,0,58"
                  Width="280" Height="72" Opacity="0">
                <Canvas Width="280" Height="72">
                    <Border x:Name="SplashLogoMotion"
                            Canvas.Left="0" Canvas.Top="0"
                            Width="72" Height="72"
                            Background="Transparent">
                        <Border.RenderTransform>
                            <TranslateTransform X="0"/>
                        </Border.RenderTransform>
                        <Border x:Name="SplashLogoWrapper"
                                Width="72" Height="72"
                                Background="Transparent"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Border.RenderTransform>
                            <Image x:Name="SplashLogoImage"
                                   Source="avares://NexStrap/Assets/nexstrap.png"
                                   Width="72" Height="72"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        </Border>
                    </Border>
                    <TextBlock x:Name="SplashTitleText"
                               Text="NexStrap"
                               Canvas.Left="86" Canvas.Top="15"
                               FontSize="30" FontWeight="Bold"
                               Foreground="#FFFFFF"
                               LetterSpacing="1"
                               Opacity="1">
                        <TextBlock.RenderTransform>
                            <TranslateTransform X="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Canvas>

            </Grid>
            <TextBlock x:Name="SplashStatusText"
                       Text="{Binding StartupStatusText}"
                       FontSize="12"
                       Foreground="White"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Margin="34,0,0,28"
                       Opacity="0"/>
            <Grid x:Name="SplashProgressArea"
                  Height="2"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Bottom"
                  Margin="32,0,32,16"
                  Opacity="0">
                <Border x:Name="SplashProgressTrack"
                        Height="2"
                        Background="#26FFFFFF"
                        CornerRadius="1"/>
                <Border x:Name="SplashProgressFill"
                        Width="0"
                        Height="2"
                        HorizontalAlignment="Left"
                        Background="#FFFFFFFF"
                        CornerRadius="1"/>
            </Grid>
        </Grid>

    </Grid>
</Window>
