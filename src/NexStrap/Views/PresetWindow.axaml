<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        xmlns:models="using:NexStrap.Models"
        x:Class="NexStrap.Views.PresetWindow"
        x:DataType="vm:FastFlagsViewModel"
        Title="Presets — Fast Flags"
        Width="400" Height="420"
        MinWidth="320" MinHeight="300"
        Background="#000000"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="30,*">

        <!-- Title bar -->
        <Grid Grid.Row="0" IsHitTestVisible="False">
            <TextBlock Text="Presets" FontSize="12" FontWeight="SemiBold"
                       Foreground="#666666" VerticalAlignment="Center" Margin="14,0"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" Margin="20,4,20,20">

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,16">
                <TextBlock Text="Optimization Preset" FontSize="13" FontWeight="SemiBold"
                           Foreground="#FFFFFF"/>
                <TextBlock FontSize="11" Foreground="#555555"
                           Text="Apply a curated set of performance flags for Roblox."/>
            </StackPanel>

            <!-- Preset group breakdown -->
            <Border Grid.Row="1" Background="#0D0D0D" CornerRadius="8" Padding="14,12">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding PresetGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:PresetGroup">
                                <StackPanel Margin="0,0,0,14">
                                    <!-- Group header -->
                                    <Grid ColumnDefinitions="18,*,Auto" Margin="0,0,0,6">
                                        <PathIcon Grid.Column="0" Data="{Binding IconPath}"
                                                  Width="13" Height="13"
                                                  Foreground="#555555" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontSize="12" FontWeight="SemiBold" Foreground="#AAAAAA"
                                                   Margin="10,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Flags.Count, StringFormat='{}{0} flags'}"
                                                   FontSize="10" Foreground="#404040"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- Flag list -->
                                    <ItemsControl ItemsSource="{Binding Flags}" Margin="28,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="models:FastFlag">
                                                <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                               FontSize="10" Foreground="#505050"
                                                               FontFamily="Consolas,Courier New,monospace"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                               FontSize="10" Foreground="#383838"
                                                               FontFamily="Consolas,Courier New,monospace"
                                                               Margin="8,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Apply / Cancel -->
            <Grid Grid.Row="2" ColumnDefinitions="*,8,Auto" Margin="0,14,0,0">
                <Button Grid.Column="0"
                        Command="{Binding TogglePresetCommand}"
                        Background="{Binding IsPresetActive,
                            Converter={StaticResource BoolToColorConverter},
                            ConverterParameter='#2A2A2A,#FFFFFF'}"
                        Foreground="{Binding IsPresetActive,
                            Converter={StaticResource BoolToColorConverter},
                            ConverterParameter='#888888,#080808'}"
                        FontSize="13" FontWeight="SemiBold"
                        Padding="0,10" CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center">
                    <TextBlock Text="{Binding IsPresetActive,
                                   Converter={StaticResource BoolToStringConverter},
                                   ConverterParameter='Remove preset flags,Apply'}"/>
                </Button>
                <Button Grid.Column="2"
                        Content="Close"
                        Background="#1A1A1A" Foreground="#666666"
                        FontSize="13" Padding="20,10" CornerRadius="8"
                        Click="Close_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
