<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.ProfileManagerWindow"
        x:DataType="vm:FastFlagsViewModel"
        Title="Profiles — Fast Flags"
        Width="420" Height="240"
        CanResize="False"
        Background="#080808"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="30,*">

        <Grid Grid.Row="0" IsHitTestVisible="False">
            <TextBlock Text="Profiles" FontSize="12" FontWeight="SemiBold"
                       Foreground="#666666" VerticalAlignment="Center" Margin="14,0"/>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto" Margin="20,4,20,20">

            <!-- Active profile selector -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,10">
                <TextBlock Grid.Column="0" Text="Active profile"
                           FontSize="12" Foreground="#555555"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          DisplayMemberBinding="{Binding Name}"
                          Background="#0D0D0D" Foreground="#FFFFFF"
                          CornerRadius="8" FontSize="12"
                          HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- New profile name -->
            <TextBox Grid.Row="1" Margin="0,0,0,10"
                     Text="{Binding NewProfileName}"
                     Watermark="New profile name..."
                     Background="#0D0D0D" Foreground="#FFFFFF"
                     BorderBrush="#2A2A2A" CornerRadius="10"
                     Padding="14,10" FontSize="12"/>

            <!-- Save / Delete -->
            <Grid Grid.Row="2" ColumnDefinitions="*,8,Auto" Margin="0,0,0,10">
                <Button Grid.Column="0"
                        Content="Save as Profile"
                        Command="{Binding SaveAsProfileCommand}"
                        Background="#FFFFFF" Foreground="#080808"
                        FontSize="13" FontWeight="SemiBold"
                        Padding="0,10" CornerRadius="10"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="Delete"
                        Command="{Binding DeleteProfileCommand}"
                        Background="#1A1A1A" Foreground="#666666"
                        FontSize="13" Padding="20,10" CornerRadius="10"/>
            </Grid>

            <!-- Close -->
            <Button Grid.Row="3"
                    Content="Close"
                    Background="Transparent" Foreground="#444444"
                    FontSize="12" Padding="0,6"
                    HorizontalAlignment="Left"
                    Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
