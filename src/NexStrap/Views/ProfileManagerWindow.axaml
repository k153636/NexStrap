<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.ProfileManagerWindow"
        x:DataType="vm:FastFlagsViewModel"
        Title="Profiles — Fast Flags"
        Width="420" Height="260"
        CanResize="False"
        Background="#000000"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="30,*">

        <Grid Grid.Row="0" IsHitTestVisible="False">
            <TextBlock Text="Profiles" FontSize="12" FontWeight="SemiBold"
                       Foreground="#666666" VerticalAlignment="Center" Margin="14,0"/>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,4,Auto,12,Auto,4,Auto,12,Auto" Margin="20,6,20,20">

            <!-- Rename label -->
            <TextBlock Grid.Row="0" Text="RENAME CURRENT" FontSize="9" FontWeight="SemiBold"
                       Foreground="#404040" LetterSpacing="1"/>

            <!-- Rename row -->
            <Grid Grid.Row="2" ColumnDefinitions="*,8,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding RenameProfileName}"
                         Watermark="Profile name..."
                         Background="#0D0D0D" Foreground="#FFFFFF"
                         BorderBrush="#2A2A2A" CornerRadius="8"
                         Padding="14,9" FontSize="12"/>
                <Button Grid.Column="2"
                        Content="Rename"
                        Command="{Binding RenameProfileCommand}"
                        Background="#1A1A1A" Foreground="#888888"
                        FontSize="12" Padding="18,9" CornerRadius="8"/>
            </Grid>

            <!-- Save as new label -->
            <TextBlock Grid.Row="4" Text="SAVE AS NEW PROFILE" FontSize="9" FontWeight="SemiBold"
                       Foreground="#404040" LetterSpacing="1"/>

            <!-- New profile name -->
            <Grid Grid.Row="6" ColumnDefinitions="*,8,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding NewProfileName}"
                         Watermark="New profile name..."
                         Background="#0D0D0D" Foreground="#FFFFFF"
                         BorderBrush="#2A2A2A" CornerRadius="8"
                         Padding="14,9" FontSize="12"/>
                <Button Grid.Column="2"
                        Content="Save as"
                        Command="{Binding SaveAsProfileCommand}"
                        Background="#FFFFFF" Foreground="#080808"
                        FontSize="12" FontWeight="SemiBold"
                        Padding="18,9" CornerRadius="8"/>
            </Grid>

            <!-- Delete + Close -->
            <Grid Grid.Row="8" ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Content="Delete"
                        Command="{Binding DeleteProfileCommand}"
                        Background="#1A1A1A" Foreground="#666666"
                        FontSize="12" Padding="20,8" CornerRadius="8"/>
                <Button Grid.Column="2"
                        Content="Close"
                        Background="Transparent" Foreground="#444444"
                        FontSize="12" Padding="0,6"
                        HorizontalAlignment="Right"
                        Click="Close_Click"/>
            </Grid>

        </Grid>
    </Grid>
</Window>
