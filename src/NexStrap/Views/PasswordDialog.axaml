<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NexStrap.Views.PasswordDialog"
        Title="NexStrap"
        Width="320" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#000000"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <StackPanel Spacing="12" Margin="24,28,24,20" VerticalAlignment="Center">
        <TextBlock Text="Authentication required" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource SubtextBrush}" HorizontalAlignment="Center"/>
        <TextBox x:Name="PasswordBox"
                 PasswordChar="●"
                 Background="#000000" Foreground="#FFFFFF"
                 BorderBrush="#2A2A2A" CornerRadius="8"
                 Padding="12,8" FontSize="13"
                 HorizontalAlignment="Stretch"/>
        <Grid ColumnDefinitions="*,8,*">
            <Button Grid.Column="0" x:Name="CancelButton"
                    Content="Cancel"
                    HorizontalAlignment="Stretch"
                    Background="#1A1A1A" Foreground="{DynamicResource MutedBrush}"
                    FontSize="12" Padding="0,8" CornerRadius="8"/>
            <Button Grid.Column="2" x:Name="OkButton"
                    Content="Confirm"
                    HorizontalAlignment="Stretch"
                    Background="#FFFFFF" Foreground="#080808"
                    FontWeight="SemiBold" FontSize="12"
                    Padding="0,8" CornerRadius="8"/>
        </Grid>
    </StackPanel>
</Window>
