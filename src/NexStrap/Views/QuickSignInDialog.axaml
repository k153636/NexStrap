<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexStrap.ViewModels"
        x:Class="NexStrap.Views.QuickSignInDialog"
        x:DataType="vm:QuickSignInViewModel"
        Title="Quick Sign In"
        Width="420" Height="280"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#111111"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Grid RowDefinitions="30,*">

        <!-- タイトルバー -->
        <Grid Grid.Row="0" Background="Transparent" PointerPressed="TitleBar_PointerPressed">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="14,0" Spacing="8" IsHitTestVisible="False">
                <TextBlock Text="↩" FontSize="13" Foreground="#888888" VerticalAlignment="Center"/>
                <TextBlock Text="Quick Sign In" FontSize="12" FontWeight="SemiBold"
                           Foreground="#CCCCCC" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- コンテンツ -->
        <StackPanel Grid.Row="1" Spacing="14" Margin="24,10,24,20" VerticalAlignment="Center">

            <!-- 説明文 -->
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#AAAAAA">
                <Run Text="Copy this code and enter it in "/>
                <Run Text="Roblox → Account Settings → Quick Login"
                     Foreground="#60A5FA" FontWeight="SemiBold"/>
                <Run Text=" on your mobile device."/>
            </TextBlock>

            <!-- コード表示 -->
            <Border Background="#1A1A1A" CornerRadius="8" Padding="0,14">
                <TextBlock Text="{Binding Code}"
                           FontSize="34" FontWeight="Bold"
                           FontFamily="Consolas,monospace"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           LetterSpacing="10"/>
            </Border>

            <!-- ステータス -->
            <Border CornerRadius="8" Padding="12,9"
                    BorderThickness="1"
                    BorderBrush="{Binding StatusColor}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="ⓘ" FontSize="13"
                               Foreground="{Binding StatusColor}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12" Foreground="{Binding StatusColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ボタン行 -->
            <Grid ColumnDefinitions="*,8,*">
                <Button Grid.Column="0"
                        Content="Copy Code"
                        Click="CopyCode_Click"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="{DynamicResource OverlayBg}"
                        Foreground="#FFFFFF"
                        FontSize="12" Padding="0,9" CornerRadius="8"/>
                <Button Grid.Column="2"
                        Content="Close"
                        Click="Close_Click"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="{DynamicResource OverlayBg}"
                        Foreground="#FFFFFF"
                        FontSize="12" Padding="0,9" CornerRadius="8"/>
            </Grid>

        </StackPanel>
    </Grid>
</Window>
