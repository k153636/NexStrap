<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.Styling"
             xmlns:local="using:NexStrap"
             x:Class="NexStrap.App"
             RequestedThemeVariant="Dark">

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="avares://NexStrap/Assets/nexstrap.png"
                      ToolTipText="NexStrap"
                      Clicked="OnTrayIconClicked">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show NexStrap" Click="OnTrayShowClicked"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Quit" Click="OnTrayExitClicked"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.Resources>
        <ResourceDictionary>
            <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <local:BoolToStringConverter x:Key="BoolToStringConverter"/>
            <local:IntToZeroConverter x:Key="IntToZeroConverter"/>
            <local:SecondsToTimeConverter x:Key="SecondsToTimeConverter"/>
            <local:StringToImageConverter x:Key="StringToImageConverter"/>

            <!-- Black/White palette -->
            <SolidColorBrush x:Key="BgBrush"        Color="#000000"/>
            <SolidColorBrush x:Key="SurfaceBrush"   Color="#141414"/>
            <SolidColorBrush x:Key="ElevatedBrush"  Color="#202020"/>
            <SolidColorBrush x:Key="BorderBrush"    Color="#2E2E2E"/>
            <SolidColorBrush x:Key="DividerBrush"   Color="#10FFFFFF"/>
            <SolidColorBrush x:Key="MutedBrush"     Color="#505050"/>
            <SolidColorBrush x:Key="SubtextBrush"   Color="#888888"/>
            <SolidColorBrush x:Key="TextBrush"      Color="#CCCCCC"/>
            <SolidColorBrush x:Key="FgBrush"        Color="#FFFFFF"/>

            <!-- Glass-switchable card brushes (updated in code when glass theme toggles) -->
            <SolidColorBrush x:Key="CardBg"     Color="#000000"/>
            <SolidColorBrush x:Key="SurfaceBg"  Color="#000000"/>
            <SolidColorBrush x:Key="ElevatedBg" Color="#101010"/>
            <SolidColorBrush x:Key="OverlayBg"  Color="#0A0A0A"/>
            <SolidColorBrush x:Key="InputBg"    Color="#000000"/>

            <!-- Glass-switchable text colors -->
            <SolidColorBrush x:Key="FgSub"   Color="#888888"/>
            <SolidColorBrush x:Key="FgMuted" Color="#505050"/>

            <!-- Semantic colors -->
            <SolidColorBrush x:Key="FgDanger" Color="#FF6B6B"/>

            <!-- SVG path data (StreamGeometry — PathIcon.Data requires Geometry, not string) -->
            <StreamGeometry x:Key="IconHome">M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z</StreamGeometry>
            <StreamGeometry x:Key="IconFlag">M14.4 6 14 4H5v17h2v-7h5.6l.4 2h7V6z</StreamGeometry>
            <StreamGeometry x:Key="IconMod">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z</StreamGeometry>
            <StreamGeometry x:Key="IconGlobe">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z</StreamGeometry>
            <StreamGeometry x:Key="IconSettings">M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.56-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z</StreamGeometry>
            <StreamGeometry x:Key="IconPlay">M8 5v14l11-7z</StreamGeometry>
            <StreamGeometry x:Key="IconMulti">M3 3h8v8H3zm10 0h8v8h-8zM3 13h8v8H3zm10 0h8v8h-8z</StreamGeometry>
            <StreamGeometry x:Key="IconFlash">M7 2v11h3v9l7-12h-4l4-8z</StreamGeometry>
            <StreamGeometry x:Key="IconStats">M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z</StreamGeometry>
            <StreamGeometry x:Key="IconPackage">M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5z</StreamGeometry>
            <StreamGeometry x:Key="IconBack">M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20z</StreamGeometry>
            <StreamGeometry x:Key="IconMusic">M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z</StreamGeometry>
            <StreamGeometry x:Key="IconVideo">M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z</StreamGeometry>
            <StreamGeometry x:Key="IconChat">M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z</StreamGeometry>
            <StreamGeometry x:Key="IconInfo">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z</StreamGeometry>
            <StreamGeometry x:Key="IconTrash">M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z</StreamGeometry>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <fa:FluentAvaloniaTheme CustomAccentColor="#FFFFFF"/>

        <!-- Global text shadow — ensures readability on any custom background -->
        <Style Selector="TextBlock">
            <Setter Property="Effect">
                <DropShadowEffect BlurRadius="4" Color="#CC000000" OffsetX="0" OffsetY="0"/>
            </Setter>
        </Style>

        <!-- Global button styles -->
        <Style Selector="Button.plain">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth"        Value="0"/>
            <Setter Property="Padding"         Value="4,0"/>
        </Style>
        <Style Selector="Button.plain:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.plain:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform"
                        Duration="0:0:0.12" Easing="CubicEaseOut"/>
                    <DoubleTransition Property="Opacity"
                        Duration="0:0:0.10" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{TemplateBinding Background}"/>
            <Setter Property="Foreground" Value="{TemplateBinding Foreground}"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{TemplateBinding Background}"/>
            <Setter Property="Foreground" Value="{TemplateBinding Foreground}"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
            <Setter Property="Opacity" Value="0.90"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ToggleSwitch cursor -->
        <Style Selector="ToggleSwitch">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ListBoxItem / NavigationViewItem cursor -->
        <Style Selector="ListBoxItem">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Application.Styles>
</Application>
